,"type":"Gesture"},"disableLogging":false,"m_SIGUID":-5676411119379887970,"m_classType":"UIInteractionAction","m_comment":"","m_constraintList":[],"m_isDisabled":false,"m_isOrCondition":false},{"cancelPrevious":false,"m_backgroundColor":-3790808,"m_displayIcon":true,"m_duration":2,"m_horizontalPosition":0,"m_imageName":"ic_do_not_disturb_white_24dp","m_imagePackageName":"com.arlosoft.macrodroid","m_imageResourceName":"ic_do_not_disturb_white_24dp","m_messageText":"{lv\u003dlangs[{lv\u003dcurrentLang}][Ad skipped]}","m_position":0,"m_textColor":-1,"m_tintIcon":false,"maintainSpaces":false,"useTextOnly":false,"disableLogging":false,"m_SIGUID":-4633348443786340725,"m_classType":"ToastAction","m_comment":"","m_constraintList":[],"m_isDisabled":false,"m_isOrCondition":false},{"m_vibratePattern":12,"waitToFinish":false,"disableLogging":false,"m_SIGUID":-8570584502736906539,"m_classType":"VibrateAction","m_comment":"","m_constraintList":[],"m_isDisabled":false,"m_isOrCondition":false},{"disableLogging":false,"m_SIGUID":-5703914397463490518,"m_classType":"EndIfAction","m_comment":"","m_constraintList":[],"m_isDisabled":false,"m_isOrCondition":false},{"disableLogging":false,"m_SIGUID":-7773686815321956832,"m_classType":"EndIfAction","m_comment":"","m_constraintList":[],"m_isDisabled":false,"m_isOrCondition":false}],"m_category":"Видео","m_constraintList":[],"m_description":"⏩ AutoSkip YouTube Ads - including Shorts\n\nThis macro automatically skips ads in regular YouTube videos and Shorts, ensuring a smooth and uninterrupted viewing experience.\n---------\n🌍 Multi-language support\n\nThe macro includes built-in translations and automatically detects which language to use.\nIf your language is missing, simply add it to the \"langs: variable and set the correct key in \"currentLang\".\n---------\n🎯 What the macro does during ads:\n\n- Mutes the sound\n- Skip all skippable ads\n\nWorks with both full-length videos and YouTube Shorts.\n---------\n⚙️ Required settings\n\n⚠️ To ensure proper functionality:\n1. Go to Android Settings -\u003e Accessibility\n2. Enable MacroDroid - UI Interaction\n\n⚠️ During operation, the macro temporarily increases the screen-reading frequency for more accurate element detection and then automatically restores the default value.\n---------\n🙌 Credits\nBased on the idea from W!lloO - YouTube: Auto skip ads:\nhttps://www.macrodroidlink.com/macrostore?id\u003d383","m_descriptionOpen":false,"m_enabled":true,"m_excludeLog":false,"m_headingColor":0,"m_isOrCondition":false,"m_name":"AutoSkip YouTube Ads ⏩","m_triggerList":[{"color":-1,"label":"Regular video","disableLogging":false,"m_SIGUID":-6554194299538392693,"m_classType":"SeparatorTrigger","m_comment":"","m_constraintList":[],"m_isDisabled":false,"m_isOrCondition":false},{"activityEnableRegex":false,"activityIgnoreCase":true,"appNameList":["YouTube"],"enableRegex":false,"ignoreCase":true,"includeOverlays":true,"isOffScreen":false,"limitToActivity":false,"matchOption":0,"packageNameList":["com.google.android.youtube"],"textToMatch":"{lv\u003dlangs[{lv\u003dcurrentLang}][Visit advertiser]}*","disableLogging":false,"m_SIGUID":-8485181191588793680,"m_classType":"ScreenContentTrigger","m_comment":"","m_constraintList":[{"m_musicActive":true,"disableLogging":false,"m_SIGUID":-8465475493142843064,"m_classType":"MusicActiveConstraint","m_comment":"","m_constraintList":[],"m_isDisabled":false,"m_isOrCondition":false},{"m_active":true,"m_applicationNameList":["YouTube"],"m_foreground":true,"m_packageNameList":["com.google.android.youtube"],"mechanismOption":0,"usePackageNameOption":0,"disableLogging":false,"m_SIGUID":-6921085024429849030,"m_classType":"ActiveApplicationConstraint","m_comment":"","m_constraintList":[],"m_isDisabled":false,"m_isOrCondition":false}],"m_isDisabled":false,"m_isOrCondition":false},{"activityEnableRegex":false,"activityIgnoreCase":true,"appNameList":["YouTube"],"enableRegex":false,"ignoreCase":true,"includeOverlays":true,"isOffScreen":true,"lim