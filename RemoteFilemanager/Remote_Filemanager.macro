sType":"IfConditionAction","m_comment":"Delete the file","m_constraintList":[{"checkCase":false,"dictionaryKeys":{"keys":[]},"dictionaryType":2,"enableRegex":false,"m_booleanValue":false,"m_doubleValue":0.0,"m_intCompareVariable":false,"m_intGreaterThan":false,"m_intLessThan":false,"m_intNotEqual":false,"m_intValue":0,"m_stringComparisonType":0,"m_stringEqual":true,"m_stringValue":"file","m_variable":{"dictionary":{"entries":[],"isArray":false,"variableType":4,"type":"Dictionary"},"isActionBlockWorkingVar":false,"isLocalVar":true,"isSecure":false,"m_booleanValue":false,"m_decimalValue":0.0,"m_intValue":0,"m_name":"type","m_stringValue":"","m_type":2,"supportsInput":true,"supportsOutput":true},"disableLogging":false,"m_SIGUID":-5808718893370569636,"m_classType":"MacroDroidVariableConstraint","m_constraintList":[],"m_isDisabled":false,"m_isOrCondition":false}],"m_isDisabled":false,"m_isOrCondition":false},{"fileExtensions":[],"fileOption":5,"filePattern":"{lv\u003drequest[file]}","folderName":"","folderPattern":"","fromPath":"{lv\u003drequest[dir]}","option":2,"toPath":"","waitToComplete":true,"disableLogging":false,"m_SIGUID":-6863309558144189451,"m_classType":"FileOperationAllFilesAction","m_constraintList":[],"m_isDisabled":false,"m_isOrCondition":false},{"dontLogIfConditionIsFalse":false,"disableLogging":false,"m_SIGUID":-8846083599098640881,"m_classType":"ElseAction","m_comment":"Delete the folder","m_constraintList":[],"m_isDisabled":false,"m_isOrCondition":false},{"fileExtensions":[],"fileOption":7,"filePattern":"","folderName":"","folderPattern":"{lv\u003drequest[file]}","fromPath":"{lv\u003drequest[dir]}","option":2,"toPath":"","waitToComplete":true,"disableLogging":false,"m_SIGUID":-6631538700695419652,"m_classType":"FileOperationAllFilesAction","m_constraintList":[],"m_isDisabled":false,"m_isOrCondition":false},{"disableLogging":false,"m_SIGUID":-5664711521566774860,"m_classType":"EndIfAction","m_constraintList":[],"m_isDisabled":false,"m_isOrCondition":false},{"color":-1,"separatorLabel":"","disableLogging":false,"m_SIGUID":-7892130361078300745,"m_classType":"SeparatorAction","m_constraintList":[],"m_isDisabled":false,"m_isOrCondition":false},{"logChannel":"Remote File Manager","logLevel":"STANDARD","logMacro":true,"m_logText":"Delete: {lv\u003drequest[full]} -\u003e {lv\u003drequest[dstFull]}","disableLogging":false,"m_SIGUID":-5296891927024628259,"m_classType":"LogAction","m_constraintList":[],"m_isDisabled":false,"m_isOrCondition":false},{"headerParams":[{"paramName":"Content-Type","paramValue":"application/json"}],"htmlText":"","option":0,"responseCode":"OK","text":"OK","disableLogging":false,"m_SIGUID":-5702603946382158928,"m_classType":"HttpServerResponseAction","m_constraintList":[],"m_isDisabled":false,"m_isOrCondition":false},{"disableLogging":false,"m_SIGUID":-4707456534907750215,"m_classType":"EndIfAction","m_constraintList":[],"m_isDisabled":false,"m_isOrCondition":false},{"color":-1,"separatorLabel":"Home page","disableLogging":false,"m_SIGUID":-5386048108671461989,"m_classType":"SeparatorAction","m_constraintList":[],"m_isDisabled":false,"m_isOrCondition":false},{"childrenCollapsed":true,"dontLogIfConditionIsFalse":false,"disableLogging":false,"m_SIGUID":-4817963639105403709,"m_classType":"IfConditionAction","m_comment":"Home page","m_constraintList":[{"checkCase":false,"dictionaryKeys":{"keys":[]},"dictionaryType":2,"enableRegex":false,"m_booleanValue":false,"m_doubleValue":0.0,"m_intCompareVariable":false,"m_intGreaterThan":false,"m_intLessThan":false,"m_intNotEqual":false,"m_intValue":0,"m_stringComparisonType":0,"m_stringEqual":true,"m_stringValue":"","m_variable":{"dictionary":{"entries":[],"isArray":false,"variableType":4,"type":"Dictionary"},"isActionBlockWorkingVar":false,"isLocalVar":true,"isSecure":false,"m_booleanValue":false,"m_decimalValue":0.0,"m_intValue":0,"m_name":"cmd","m_stringValue":"","m_type":2,"supportsInput":true,"supportsOutput":true},"disableLogging":false,"m_SIGUID":-7168259652337145310,"m_classType":"MacroDroidVariableConstraint","m_constraintList":[],"m_isDisabled":false,"m_isOrCondition":false}],"m_isDisabled":false,"m_isOrCondition":false},{"logChannel":"Remote File Manager","logLevel":"STANDARD","logMacro":true,"m_logText":"Open RFM","disableLogging":false,"m_SIGUID":-8143813871574646881,"m_classType":"LogAction","m_constraintList":[],"m_isDisabled":true,"m_isOrCondition":false},{"headerParams":[],"htmlText":"\u003c!--\r\nAuthor: BespredeL (Aleksandr Kireev)\r\nDate: 2026-04-12\r\nVersion: 1.0.0\r\nLicense: MIT\r\nGitHub: https://github.com/BespredeL/MacroDroid\r\nWebsite: https://bespredel.name\r\n\r\n-----------------------------------------------\r\n\r\nMacroDroid File Manager - contract HTTP API (all methods GET).\r\nBase URL: {lv \u003d apiUrl} (without trailing slash). Calls: {host}?cmd\u003d...\u0026...\r\n\r\nCommon parameters names:\r\nfull - full path to the object (file without trailing /; directory with trailing slash, except root \"/\").\r\ndir  - parent directory (full path with trailing slash).\r\nfile - only name (last segment); for root list \"/\" field file is empty.\r\n\r\nImmediately after cmd for all listed below commands goes type\u003ddir|file (folder or file). For rename/move/copy type one on pair src/dst.\r\n\r\nGET ?cmd\u003dlist\u0026type\u003ddir\u0026full\u003d\u0026dir\u003d\u0026file\u003d\r\nList of directory; type always dir.\r\n\r\nGET ?cmd\u003ddownload\u0026type\u003dfile\u0026full\u003d\u0026dir\u003d\u0026file\u003d\r\nDownload; type \u003d file.\r\n\r\nGET ?cmd\u003drename\u0026type\u003ddir|file\u0026srcFull\u003d\u0026srcDir\u003d\u0026srcFile\u003d\u0026dstFull\u003d\u0026dstDir\u003d\u0026dstFile\u003d\r\nRenaming.\r\n\r\nGET ?cmd\u003dmove\u0026type\u003ddir|file\u0026srcFull\u003d\u0026srcDir\u003d\u0026srcFile\u003d\u0026dstFull\u003d\u0026dstDir\u003d\u0026dstFile\u003d\r\nGET ?cmd\u003dcopy\u0026type\u003ddir|file\u0026srcFull\u003d\u0026srcDir\u003d\u0026srcFile\u003d\u0026dstFull\u003d\u0026dstDir\u003d\u0026dstFile\u003d\r\nCopying / moving.\r\n\r\nGET ?cmd\u003ddelete\u0026type\u003ddir|file\u0026full\u003d\u0026dir\u003d\u0026file\u003d\r\nDeleting file or directory.\r\n\r\nGET ?cmd\u003dupload\u0026type\u003dfile\u0026full\u003d\u0026dir\u003d\u0026file\u003d\u0026data\u003d\r\nCreating file: full/dir/file; data - Base64 body (encodeURIComponent).\r\nSize limit - see MAX_GET_UPLOAD_BYTES in script.\r\n\r\nResponse list: JSON-object; in values of field fullPath, isDirectory, size_bytes, lastModified.\r\n--\u003e\r\n\u003c!DOCTYPE html\u003e\r\n\u003chtml lang\u003d\"{lv\u003dcurrentLang}\"\u003e\r\n\u003chead\u003e\r\n    \u003cmeta charset\u003d\"UTF-8\"\u003e\r\n    \u003cmeta name\u003d\"viewport\" content\u003d\"width\u003ddevice-width, initial-scale\u003d1.0, viewport-fit\u003dcover\"\u003e\r\n    \u003cmeta name\u003d\"md-page-lang\" content\u003d\"{lv\u003dcurrentLang}\"\u003e\r\n    \u003ctitle\u003eMacroDroid File Manager - BespredeL\u003c/title\u003e\r\n    \u003clink rel\u003d\"preconnect\" href\u003d\"https://fonts.googleapis.com\"\u003e\r\n    \u003clink rel\u003d\"preconnect\" href\u003d\"https://fonts.gstatic.com\" crossorigin\u003e\r\n    \u003clink href\u003d\"https://fonts.googleapis.com/css2?family\u003dInter:wght@400;500;600;700\u0026family\u003dJetBrains+Mono:wght@400;500\u0026display\u003dswap\" rel\u003d\"stylesheet\"\u003e\r\n\r\n    \u003cstyle\u003e\r\n        :root {\r\n            --bg-deep: #070b14;\r\n            --bg-card: rgba(15, 23, 42, 0.72);\r\n            --bg-elevated: rgba(30, 41, 59, 0.85);\r\n            --border: rgba(148, 163, 184, 0.12);\r\n            --text: #f1f5f9;\r\n            --text-muted: #94a3b8;\r\n            --accent-1: #22d3ee;\r\n            --accent-2: #a78bfa;\r\n            --accent-3: #fb7185;\r\n            --success: #34d399;\r\n            --header-glow: rgba(34, 211, 238, 0.15);\r\n            --radius-lg: 20px;\r\n            --radius-md: 12px;\r\n            --radius-sm: 10px;\r\n            --shadow-soft: 0 25px 80px rgba(0, 0, 0, 0.45);\r\n            --tap-min: 44px;\r\n        }\r\n\r\n        *,\r\n        *::before,\r\n        *::after {\r\n            box-sizing: border-box;\r\n        }\r\n\r\n        html {\r\n            -webkit-text-size-adjust: 100%;\r\n        }\r\n\r\n        body {\r\n            margin: 0;\r\n            height: 100dvh;\r\n            overflow: hidden;\r\n            font-family: \"Inter\", system-ui, sans-serif;\r\n            font-size: 15px;\r\n            line-height: 1.5;\r\n            color: var(--text);\r\n            background: var(--bg-deep);\r\n            background-image: radial-gradient(ellipse 120% 80% at 50% -20%, rgba(34, 211, 238, 0.18), transparent 55%),\r\n            radial-gradient(ellipse 80% 50% at 100% 50%, rgba(167, 139, 250, 0.12), transparent 50%),\r\n            radial-gradient(ellipse 60% 40% at 0% 80%, rgba(251, 113, 133, 0.1), transparent 45%);\r\n        }\r\n\r\n        #app {\r\n            position: fixed;\r\n            left: 50%;\r\n            top: clamp(12px, 3vw, 28px);\r\n            bottom: clamp(12px, 3vw, 28px);\r\n            transform: translateX(-50%);\r\n            width: min(1100px, calc(100vw - 24px));\r\n            max-height: calc(100dvh - 24px);\r\n            display: flex;\r\n            flex-direction: column;\r\n            background: var(--bg-card);\r\n            backdrop-filter: blur(20px);\r\n            -webkit-backdrop-filter: blur(20px);\r\n            border-radius: var(--radius-lg);\r\n            border: 1px solid var(--border);\r\n            overflow: hidden;\r\n            box-shadow: var(--shadow-soft), 0 0 0 1px rgba(255, 255, 255, 0.04) inset;\r\n        }\r\n\r\n        .app-chrome {\r\n            flex-shrink: 0;\r\n        }\r\n\r\n        .app-body {\r\n            flex: 1 1 auto;\r\n            min-height: 0;\r\n            display: flex;\r\n            flex-direction: column;\r\n            overflow: hidden;\r\n        }\r\n\r\n        .table-scroll {\r\n            flex: 1 1 auto;\r\n            min-height: 0;\r\n            overflow: auto;\r\n            -webkit-overflow-scrolling: touch;\r\n            overscroll-behavior: contain;\r\n        }\r\n\r\n        header {\r\n            display: flex;\r\n            align-items: center;\r\n            gap: 14px;\r\n            padding: clamp(16px, 3vw, 22px) clamp(18px, 4vw, 26px);\r\n            background: linear-gradient(125deg, #0e7490 0%, #4f46e5 45%, #7c3aed 100%);\r\n            position: relative;\r\n            overflow: hidden;\r\n        }\r\n\r\n        header::after {\r\n            content: \"\";\r\n            position: absolute;\r\n            inset: 0;\r\n            background: linear-gradient(180deg, var(--header-glow), transparent 60%);\r\n            pointer-events: none;\r\n        }\r\n\r\n        .header-icon {\r\n            width: 48px;\r\n            height: 48px;\r\n            border-radius: 14px;\r\n            background: rgba(255, 255, 255, 0.18);\r\n            display: grid;\r\n            place-items: center;\r\n            font-size: 1.5rem;\r\n            flex-shrink: 0;\r\n            box-shadow: 0 4px 20px rgba(0, 0, 0, 0.2);\r\n        }\r\n\r\n        .header-text {\r\n            position: relative;\r\n            z-index: 1;\r\n        }\r\n\r\n        .header-text h1 {\r\n            margin: 0;\r\n            font-size: clamp(1.1rem, 2.5vw, 1.35rem);\r\n            font-weight: 700;\r\n            letter-spacing: -0.02em;\r\n            text-shadow: 0 1px 2px rgba(0, 0, 0, 0.2);\r\n        }\r\n\r\n        .header-text p {\r\n            margin: 4px 0 0;\r\n            font-size: 0.8rem;\r\n            font-weight: 500;\r\n            opacity: 0.88;\r\n        }\r\n\r\n        .header-developer {\r\n            position: relative;\r\n            z-index: 1;\r\n            margin-left: auto;\r\n            flex-shrink: 0;\r\n            text-align: right;\r\n            max-width: min(200px, 42vw);\r\n        }\r\n\r\n        .header-copyright {\r\n            margin: 0;\r\n            font-size: 0.72rem;\r\n            font-weight: 500;\r\n            line-height: 1.35;\r\n            color: rgba(248, 250, 252, 0.82);\r\n            text-shadow: 0 1px 1px rgba(0, 0, 0, 0.2);\r\n        }\r\n\r\n        .header-copyright a {\r\n            color: #e0f2fe;\r\n            text-decoration: none;\r\n            border-bottom: 1px solid rgba(224, 242, 254, 0.35);\r\n        }\r\n\r\n        .header-copyright a:hover {\r\n            border-bottom-color: rgba(224, 242, 254, 0.75);\r\n        }\r\n\r\n        #toolbar {\r\n            position: relative;\r\n            display: flex;\r\n            flex-wrap: wrap;\r\n            gap: 10px;\r\n            padding: 14px 16px;\r\n            background: rgba(2, 6, 23, 0.55);\r\n            border-bottom: 1px solid var(--border);\r\n        }\r\n\r\n        .btn {\r\n            display: inline-flex;\r\n            align-items: center;\r\n            justify-content: center;\r\n            gap: 8px;\r\n            min-height: var(--tap-min);\r\n            padding: 0 18px;\r\n            border: none;\r\n            border-radius: var(--radius-sm);\r\n            font-family: inherit;\r\n            font-size: 0.9rem;\r\n            font-weight: 600;\r\n            cursor: pointer;\r\n            transition: transform 0.15s ease, box-shadow 0.2s ease, background 0.2s ease;\r\n        }\r\n\r\n        .btn:active {\r\n            transform: scale(0.98);\r\n        }\r\n\r\n        .btn:focus-visible {\r\n            outline: 2px solid var(--accent-1);\r\n            outline-offset: 2px;\r\n        }\r\n\r\n        .btn-primary {\r\n            background: linear-gradient(135deg, #0891b2, #6366f1);\r\n            color: #fff;\r\n            box-shadow: 0 4px 16px rgba(99, 102, 241, 0.35);\r\n        }\r\n\r\n        .btn-primary:hover {\r\n            box-shadow: 0 6px 24px rgba(34, 211, 238, 0.35);\r\n        }\r\n\r\n        .btn-ghost {\r\n            background: var(--bg-elevated);\r\n            color: var(--text);\r\n            border: 1px solid var(--border);\r\n        }\r\n\r\n        .btn-ghost:hover {\r\n            background: rgba(51, 65, 85, 0.9);\r\n            border-color: rgba(148, 163, 184, 0.25);\r\n        }\r\n\r\n        #path-wrap {\r\n            padding: 12px 16px;\r\n            background: rgba(2, 6, 23, 0.4);\r\n            border-bottom: 1px solid var(--border);\r\n        }\r\n\r\n        .upload-hint {\r\n            margin-top: 10px;\r\n            font-size: 0.78rem;\r\n            color: var(--text-muted);\r\n            line-height: 1.45;\r\n        }\r\n\r\n        .upload-hint strong {\r\n            color: #c4b5fd;\r\n            font-weight: 600;\r\n        }\r\n\r\n        #upload-input {\r\n            position: absolute;\r\n            width: 1px;\r\n            height: 1px;\r\n            padding: 0;\r\n            margin: -1px;\r\n            overflow: hidden;\r\n            clip: rect(0, 0, 0, 0);\r\n            white-space: nowrap;\r\n            border: 0;\r\n        }\r\n\r\n        .btn-upload {\r\n            background: linear-gradient(135deg, rgba(52, 211, 153, 0.2), rgba(34, 211, 238, 0.15));\r\n            border: 1px solid rgba(52, 211, 153, 0.35);\r\n            color: #a7f3d0;\r\n        }\r\n\r\n        .btn-upload:hover {\r\n            background: linear-gradient(135deg, rgba(52, 211, 153, 0.35), rgba(34, 211, 238, 0.25));\r\n            border-color: rgba(52, 211, 153, 0.5);\r\n        }\r\n\r\n        .btn-buffer {\r\n            background: rgba(251, 191, 36, 0.12);\r\n            border: 1px solid rgba(251, 191, 36, 0.35);\r\n            color: #fcd34d;\r\n        }\r\n\r\n        .btn-buffer:hover {\r\n            background: rgba(251, 191, 36, 0.22);\r\n            border-color: rgba(251, 191, 36, 0.5);\r\n        }\r\n\r\n        .btn-buffer:disabled {\r\n            opacity: 0.45;\r\n            cursor: not-allowed;\r\n            transform: none;\r\n        }\r\n\r\n        #nav-up-btn:disabled {\r\n            opacity: 0.45;\r\n            cursor: not-allowed;\r\n            transform: none;\r\n            box-shadow: none;\r\n        }\r\n\r\n        #clip-paste-btn[hidden],\r\n        #clip-cancel-btn[hidden] {\r\n            display: none !important;\r\n            visibility: hidden !important;\r\n            pointer-events: none !important;\r\n            position: absolute !important;\r\n            width: 0 !important;\r\n            height: 0 !important;\r\n            margin: 0 !important;\r\n            padding: 0 !important;\r\n            overflow: hidden !important;\r\n            border: 0 !important;\r\n            clip: rect(0, 0, 0, 0) !important;\r\n        }\r\n\r\n        .path-wrap-row {\r\n            display: flex;\r\n            gap: 8px;\r\n            align-items: stretch;\r\n        }\r\n\r\n        #path {\r\n            flex: 1;\r\n            min-width: 0;\r\n            width: 100%;\r\n            box-sizing: border-box;\r\n            font-family: \"JetBrains Mono\", ui-monospace, monospace;\r\n            font-size: clamp(0.75rem, 2vw, 0.85rem);\r\n            font-weight: 500;\r\n            color: var(--accent-1);\r\n            word-break: break-all;\r\n            padding: 10px 14px;\r\n            border-radius: var(--radius-sm);\r\n            background: rgba(15, 23, 42, 0.9);\r\n            border: 1px solid rgba(34, 211, 238, 0.2);\r\n        }\r\n\r\n        #path:focus {\r\n            outline: none;\r\n            border-color: rgba(34, 211, 238, 0.55);\r\n            box-shadow: 0 0 0 3px rgba(34, 211, 238, 0.12);\r\n        }\r\n\r\n        #path-go-btn {\r\n            flex-shrink: 0;\r\n            min-height: var(--tap-min);\r\n            padding: 0 14px;\r\n        }\r\n\r\n        table {\r\n            width: 100%;\r\n            min-width: 520px;\r\n            border-collapse: collapse;\r\n        }\r\n\r\n        thead {\r\n            background: linear-gradient(180deg, rgba(30, 41, 59, 0.95), rgba(15, 23, 42, 0.6));\r\n        }\r\n\r\n        th {\r\n            padding: 14px 16px;\r\n            text-align: left;\r\n            font-size: 0.72rem;\r\n            font-weight: 700;\r\n            text-transform: uppercase;\r\n            letter-spacing: 0.08em;\r\n            color: var(--text-muted);\r\n            border-bottom: 1px solid var(--border);\r\n        }\r\n\r\n        th:nth-child(2),\r\n        th:nth-child(3),\r\n        td:nth-child(2),\r\n        td:nth-child(3) {\r\n            white-space: nowrap;\r\n        }\r\n\r\n        tbody tr {\r\n            border-bottom: 1px solid var(--border);\r\n            cursor: pointer;\r\n            transition: background 0.15s ease;\r\n        }\r\n\r\n        tbody tr:hover {\r\n            background: rgba(51, 65, 85, 0.35);\r\n        }\r\n\r\n        tbody tr:focus-within {\r\n            background: rgba(99, 102, 241, 0.12);\r\n        }\r\n\r\n        td {\r\n            padding: 12px 16px;\r\n            vertical-align: middle;\r\n        }\r\n\r\n        .name {\r\n            display: flex;\r\n            align-items: center;\r\n            gap: 12px;\r\n            min-width: 0;\r\n        }\r\n\r\n        .icon {\r\n            font-size: 1.35rem;\r\n            line-height: 1;\r\n            flex-shrink: 0;\r\n            filter: drop-shadow(0 2px 4px rgba(0, 0, 0, 0.25));\r\n        }\r\n\r\n        .file-title {\r\n            font-weight: 600;\r\n            color: var(--text);\r\n            overflow: hidden;\r\n            text-overflow: ellipsis;\r\n            white-space: nowrap;\r\n        }\r\n\r\n        .meta {\r\n            font-size: 0.8rem;\r\n            color: var(--text-muted);\r\n            font-variant-numeric: tabular-nums;\r\n        }\r\n\r\n        .size-pill {\r\n            display: inline-block;\r\n            padding: 4px 10px;\r\n            border-radius: 999px;\r\n            background: rgba(167, 139, 250, 0.12);\r\n            color: #c4b5fd;\r\n            font-size: 0.78rem;\r\n            font-weight: 500;\r\n        }\r\n\r\n        .actions-desktop {\r\n            margin-left: auto;\r\n            display: flex;\r\n            gap: 6px;\r\n            flex-shrink: 0;\r\n            opacity: 0;\r\n            transition: opacity 0.2s ease;\r\n        }\r\n\r\n        tbody tr:hover .actions-desktop,\r\n        tbody tr:focus-within .actions-desktop {\r\n            opacity: 1;\r\n        }\r\n\r\n        @media (hover: none) and (pointer: coarse) {\r\n            .actions-desktop {\r\n                opacity: 1;\r\n            }\r\n        }\r\n\r\n        .actions-mobile {\r\n            display: none;\r\n            position: relative;\r\n            margin-left: auto;\r\n            flex-shrink: 0;\r\n        }\r\n\r\n        .row-menu-trigger {\r\n            font-size: 1.25rem;\r\n            font-weight: 700;\r\n            letter-spacing: 0.02em;\r\n            line-height: 1;\r\n        }\r\n\r\n        .row-menu-dropdown {\r\n            position: fixed;\r\n            z-index: 160;\r\n            display: none;\r\n            flex-direction: column;\r\n            gap: 4px;\r\n            min-width: 220px;\r\n            padding: 8px;\r\n            border-radius: var(--radius-md);\r\n            background: linear-gradient(165deg, rgba(30, 41, 59, 0.98), rgba(15, 23, 42, 0.99));\r\n            border: 1px solid var(--border);\r\n            box-shadow: var(--shadow-soft), 0 12px 40px rgba(0, 0, 0, 0.45);\r\n        }\r\n\r\n        .row-menu-dropdown.is-open {\r\n            display: flex;\r\n        }\r\n\r\n        .row-menu-item {\r\n            display: flex;\r\n            align-items: center;\r\n            gap: 10px;\r\n            width: 100%;\r\n            padding: 12px 14px;\r\n            border: none;\r\n            border-radius: var(--radius-sm);\r\n            background: rgba(2, 6, 23, 0.45);\r\n            color: var(--text);\r\n            font-family: inherit;\r\n            font-size: 0.9rem;\r\n            font-weight: 600;\r\n            text-align: left;\r\n            cursor: pointer;\r\n            transition: background 0.15s ease;\r\n        }\r\n\r\n        .row-menu-item:hover {\r\n            background: rgba(79, 70, 229, 0.35);\r\n        }\r\n\r\n        .row-menu-item.is-danger {\r\n            color: #fecaca;\r\n        }\r\n\r\n        .row-menu-item.is-danger:hover {\r\n            background: rgba(251, 113, 133, 0.2);\r\n        }\r\n\r\n        .action-btn {\r\n            background: rgba(30, 41, 59, 0.95);\r\n            border: 1px solid var(--border);\r\n            border-radius: 10px;\r\n            min-width: 40px;\r\n            min-height: 40px;\r\n            padding: 0;\r\n            cursor: pointer;\r\n            display: flex;\r\n            align-items: center;\r\n            justify-content: center;\r\n            font-size: 1rem;\r\n            transition: background 0.15s ease, border-color 0.15s ease, transform 0.1s ease;\r\n        }\r\n\r\n        .action-btn:hover {\r\n            background: rgba(79, 70, 229, 0.45);\r\n            border-color: rgba(167, 139, 250, 0.4);\r\n        }\r\n\r\n        .action-btn:focus-visible {\r\n            outline: 2px solid var(--accent-2);\r\n            outline-offset: 2px;\r\n        }\r\n\r\n        .action-btn:active {\r\n            transform: scale(0.95);\r\n        }\r\n\r\n        .action-btn.danger:hover {\r\n            background: rgba(251, 113, 133, 0.25);\r\n            border-color: rgba(251, 113, 133, 0.45);\r\n        }\r\n\r\n        #loader {\r\n            position: absolute;\r\n            inset: 0;\r\n            display: none;\r\n            align-items: center;\r\n            justify-content: center;\r\n            background: rgba(7, 11, 20, 0.55);\r\n            backdrop-filter: blur(4px);\r\n            z-index: 10;\r\n        }\r\n\r\n        #loader.is-visible {\r\n            display: flex;\r\n        }\r\n\r\n        .spinner-wrap {\r\n            display: flex;\r\n            flex-direction: column;\r\n            align-items: center;\r\n            gap: 14px;\r\n        }\r\n\r\n        .spinner {\r\n            width: 44px;\r\n            height: 44px;\r\n            border-radius: 50%;\r\n            border: 3px solid rgba(148, 163, 184, 0.2);\r\n            border-top-color: var(--accent-1);\r\n            border-right-color: var(--accent-2);\r\n            animation: spin 0.85s linear infinite;\r\n        }\r\n\r\n        .spinner-label {\r\n            font-size: 0.85rem;\r\n            font-weight: 500;\r\n            color: var(--text-muted);\r\n        }\r\n\r\n        @keyframes spin {\r\n            to {\r\n                transform: rotate(360deg);\r\n            }\r\n        }\r\n\r\n        .modal-bg {\r\n            position: fixed;\r\n            inset: 0;\r\n            z-index: 180;\r\n            padding: 16px;\r\n            background: rgba(2, 6, 23, 0.75);\r\n            backdrop-filter: blur(8px);\r\n            display: none;\r\n            align-items: center;\r\n            justify-content: center;\r\n        }\r\n\r\n        .modal-bg.is-open {\r\n            display: flex;\r\n        }\r\n\r\n        .modal {\r\n            width: min(100%, 400px);\r\n            padding: clamp(20px, 4vw, 28px);\r\n            border-radius: var(--radius-md);\r\n            background: linear-gradient(165deg, rgba(30, 41, 59, 0.98), rgba(15, 23, 42, 0.99));\r\n            border: 1px solid var(--border);\r\n            box-shadow: var(--shadow-soft), 0 0 40px rgba(99, 102, 241, 0.12);\r\n        }\r\n\r\n        #modalTitle {\r\n            font-size: 1.1rem;\r\n            font-weight: 700;\r\n            color: var(--text);\r\n            margin-bottom: 4px;\r\n        }\r\n\r\n        .modal-hint {\r\n            font-size: 0.8rem;\r\n            color: var(--text-muted);\r\n            margin-bottom: 12px;\r\n        }\r\n\r\n        .modal input {\r\n            width: 100%;\r\n            margin-top: 12px;\r\n            padding: 12px 14px;\r\n            font-family: \"JetBrains Mono\", monospace;\r\n            font-size: 0.9rem;\r\n            background: rgba(2, 6, 23, 0.6);\r\n            border: 1px solid var(--border);\r\n            border-radius: var(--radius-sm);\r\n            color: var(--text);\r\n            transition: border-color 0.2s ease, box-shadow 0.2s ease;\r\n        }\r\n\r\n        .modal input:focus {\r\n            outline: none;\r\n            border-color: rgba(34, 211, 238, 0.5);\r\n            box-shadow: 0 0 0 3px rgba(34, 211, 238, 0.15);\r\n        }\r\n\r\n        .modal-actions {\r\n            margin-top: 20px;\r\n            display: flex;\r\n            flex-wrap: wrap;\r\n            justify-content: flex-end;\r\n            gap: 10px;\r\n        }\r\n\r\n        .modal-actions .btn {\r\n            min-height: 44px;\r\n        }\r\n\r\n        .btn-danger {\r\n            background: linear-gradient(135deg, #be123c, #fb7185);\r\n            color: #fff;\r\n            box-shadow: 0 4px 16px rgba(251, 113, 133, 0.3);\r\n        }\r\n\r\n        .list-error {\r\n            display: none;\r\n            flex-direction: column;\r\n            align-items: center;\r\n            justify-content: center;\r\n            gap: 16px;\r\n            min-height: 220px;\r\n            padding: 28px 20px;\r\n            text-align: center;\r\n        }\r\n\r\n        .list-error:not([hidden]).is-visible {\r\n            display: flex;\r\n        }\r\n\r\n        .list-error-icon {\r\n            font-size: 2.5rem;\r\n            line-height: 1;\r\n            filter: drop-shadow(0 4px 12px rgba(251, 113, 133, 0.35));\r\n        }\r\n\r\n        .list-error-text {\r\n            margin: 0;\r\n            max-width: 360px;\r\n            font-size: 0.95rem;\r\n            line-height: 1.55;\r\n            color: var(--text-muted);\r\n        }\r\n\r\n        .list-error-text strong {\r\n            display: block;\r\n            margin-bottom: 8px;\r\n            font-size: 1.05rem;\r\n            color: var(--text);\r\n        }\r\n\r\n        #files-table.is-hidden {\r\n            display: none;\r\n        }\r\n\r\n        .toast {\r\n            position: fixed;\r\n            left: 50%;\r\n            bottom: max(20px, env(safe-area-inset-bottom, 20px));\r\n            transform: translateX(-50%) translateY(120%);\r\n            z-index: 200;\r\n            max-width: min(calc(100vw - 32px), 400px);\r\n            padding: 14px 18px;\r\n            border-radius: var(--radius-md);\r\n            font-size: 0.9rem;\r\n            font-weight: 500;\r\n            line-height: 1.45;\r\n            box-shadow: var(--shadow-soft);\r\n            border: 1px solid var(--border);\r\n            transition: transform 0.35s cubic-bezier(0.22, 1, 0.36, 1), opacity 0.25s ease;\r\n            opacity: 0;\r\n            pointer-events: none;\r\n        }\r\n\r\n        .toast.is-visible {\r\n            transform: translateX(-50%) translateY(0);\r\n            opacity: 1;\r\n            pointer-events: auto;\r\n        }\r\n\r\n        .toast.toast-error {\r\n            background: linear-gradient(165deg, rgba(127, 29, 29, 0.95), rgba(30, 41, 59, 0.98));\r\n            color: #fecaca;\r\n            border-color: rgba(251, 113, 133, 0.35);\r\n        }\r\n\r\n        .toast.toast-ok {\r\n            background: linear-gradient(165deg, rgba(6, 78, 59, 0.95), rgba(30, 41, 59, 0.98));\r\n            color: #a7f3d0;\r\n            border-color: rgba(52, 211, 153, 0.35);\r\n        }\r\n\r\n        @media (min-width: 641px) {\r\n            .actions-mobile {\r\n                display: none !important;\r\n            }\r\n        }\r\n\r\n        @media (max-width: 640px) {\r\n            #app {\r\n                left: 0;\r\n                right: 0;\r\n                top: 0;\r\n                bottom: 0;\r\n                transform: none;\r\n                width: 100%;\r\n                max-height: none;\r\n                border-radius: 0;\r\n            }\r\n\r\n            .actions-desktop {\r\n                display: none !important;\r\n            }\r\n\r\n            .actions-mobile {\r\n                display: block;\r\n            }\r\n\r\n            #toolbar {\r\n                padding: 12px;\r\n            }\r\n\r\n            .btn {\r\n                flex: 1 1 calc(50% - 5px);\r\n                min-width: 0;\r\n            }\r\n\r\n            table {\r\n                min-width: 100%;\r\n            }\r\n\r\n            thead {\r\n                display: none;\r\n            }\r\n\r\n            tbody tr {\r\n                display: block;\r\n                padding: 14px 16px;\r\n                border-bottom: 1px solid var(--border);\r\n            }\r\n\r\n            tbody td {\r\n                display: block;\r\n                padding: 4px 0;\r\n                border: none;\r\n            }\r\n\r\n            tbody td:nth-child(1) {\r\n                padding-bottom: 4px;\r\n            }\r\n\r\n            tbody td:nth-child(2)::before,\r\n            tbody td:nth-child(3)::before {\r\n                color: var(--text-muted);\r\n                font-size: 0.75rem;\r\n                font-weight: 600;\r\n            }\r\n\r\n            .name {\r\n                flex-wrap: nowrap;\r\n                align-items: center;\r\n            }\r\n\r\n            .file-title {\r\n                white-space: normal;\r\n                word-break: break-word;\r\n                flex: 1;\r\n                min-width: 0;\r\n            }\r\n\r\n            .path-wrap-row {\r\n                flex-wrap: wrap;\r\n            }\r\n\r\n            #path-go-btn {\r\n                flex: 1 1 auto;\r\n                min-width: min(100%, 120px);\r\n            }\r\n        }\r\n    \u003c/style\u003e\r\n    \u003cstyle id\u003d\"i18n-mobile-col-labels\"\u003e\u003c/style\u003e\r\n    \u003cscript type\u003d\"application/json\" id\u003d\"md-i18n-json\"\u003e{lv\u003dlangStr}\u003c/script\u003e\r\n\u003c/head\u003e\r\n\u003cbody\u003e\r\n\r\n\u003cdiv id\u003d\"app\"\u003e\r\n    \u003cdiv class\u003d\"app-chrome\"\u003e\r\n        \u003cheader\u003e\r\n            \u003cdiv class\u003d\"header-icon\" aria-hidden\u003d\"true\"\u003e📂\u003c/div\u003e\r\n            \u003cdiv class\u003d\"header-text\"\u003e\r\n                \u003ch1 data-i18n\u003d\"File Manager\"\u003eFile Manager\u003c/h1\u003e\r\n                \u003cp data-i18n\u003d\"MacroDroid · browse and manage files\"\u003eMacroDroid · просмотр и управление файлами\u003c/p\u003e\r\n            \u003c/div\u003e\r\n            \u003cdiv class\u003d\"header-developer\"\u003e\r\n                \u003cp class\u003d\"header-copyright\"\u003e\r\n                    © BespredeL (Aleksandr Kireev) ·\r\n                    \u003ca href\u003d\"https://github.com/BespredeL/MacroDroid\" target\u003d\"_blank\" rel\u003d\"noopener noreferrer\"\u003eGitHub\u003c/a\u003e\r\n                \u003c/p\u003e\r\n            \u003c/div\u003e\r\n        \u003c/header\u003e\r\n        \u003cdiv id\u003d\"toolbar\"\u003e\r\n            \u003cbutton type\u003d\"button\" class\u003d\"btn btn-primary\" id\u003d\"nav-up-btn\" onclick\u003d\"goUp()\"\u003e\u003cspan aria-hidden\u003d\"true\"\u003e⬅\u003c/span\u003e \u003cspan data-i18n\u003d\"Back\"\u003eНазад\u003c/span\u003e\u003c/button\u003e\r\n            \u003cbutton type\u003d\"button\" class\u003d\"btn btn-ghost\" onclick\u003d\"render()\"\u003e\u003cspan aria-hidden\u003d\"true\"\u003e⟳\u003c/span\u003e \u003cspan data-i18n\u003d\"Refresh\"\u003eОбновить\u003c/span\u003e\u003c/button\u003e\r\n            \u003cbutton type\u003d\"button\" class\u003d\"btn btn-upload\" id\u003d\"upload-trigger\" data-i18n-title\u003d\"Upload to current folder\" title\u003d\"\"\u003e\r\n                \u003cspan aria-hidden\u003d\"true\"\u003e⬆\u003c/span\u003e \u003cspan data-i18n\u003d\"Upload\"\u003eЗагрузить\u003c/span\u003e\r\n            \u003c/button\u003e\r\n            \u003cbutton type\u003d\"button\" class\u003d\"btn btn-buffer\" id\u003d\"clip-paste-btn\" hidden\u003e\r\n                \u003cspan aria-hidden\u003d\"true\"\u003e📋\u003c/span\u003e \u003cspan data-i18n\u003d\"Paste here\"\u003eВставить сюда\u003c/span\u003e\r\n            \u003c/button\u003e\r\n            \u003cbutton type\u003d\"button\" class\u003d\"btn btn-buffer\" id\u003d\"clip-cancel-btn\" hidden data-i18n-title\u003d\"Clear buffer\" title\u003d\"\"\u003e\r\n                \u003cspan data-i18n\u003d\"Cancel\"\u003eОтмена\u003c/span\u003e\r\n            \u003c/button\u003e\r\n            \u003cinput type\u003d\"file\" id\u003d\"upload-input\" multiple /\u003e\r\n        \u003c/div\u003e\r\n        \u003cdiv id\u003d\"path-wrap\"\u003e\r\n            \u003cdiv class\u003d\"path-wrap-row\"\u003e\r\n                \u003cinput\r\n                        id\u003d\"path\"\r\n                        type\u003d\"text\"\r\n                        spellcheck\u003d\"false\"\r\n                        autocomplete\u003d\"off\"\r\n                        data-i18n-aria\u003d\"Folder path. Press Enter or Go to open the list\"\r\n                        aria-label\u003d\"\"\r\n                /\u003e\r\n                \u003cbutton type\u003d\"button\" class\u003d\"btn btn-ghost\" id\u003d\"path-go-btn\"\u003e\u003cspan data-i18n\u003d\"Go\"\u003eПерейти\u003c/span\u003e\u003c/button\u003e\r\n            \u003c/div\u003e\r\n            \u003cdiv id\u003d\"upload-hint\" class\u003d\"upload-hint\" hidden\u003e\u003c/div\u003e\r\n            \u003cdiv id\u003d\"clip-buffer-hint\" class\u003d\"upload-hint\" hidden\u003e\u003c/div\u003e\r\n        \u003c/div\u003e\r\n    \u003c/div\u003e\r\n    \u003cdiv class\u003d\"app-body\"\u003e\r\n        \u003cdiv class\u003d\"table-scroll\" id\u003d\"table-scroll\"\u003e\r\n            \u003cdiv id\u003d\"list-error\" class\u003d\"list-error\" role\u003d\"alert\" aria-live\u003d\"assertive\"\u003e\r\n                \u003cdiv class\u003d\"list-error-icon\" aria-hidden\u003d\"true\"\u003e📡\u003c/div\u003e\r\n                \u003cp class\u003d\"list-error-text\" id\u003d\"list-error-text\"\u003e\u003c/p\u003e\r\n                \u003cbutton type\u003d\"button\" class\u003d\"btn btn-primary\" id\u003d\"list-error-retry\"\u003e\u003cspan data-i18n\u003d\"Retry\"\u003eПовторить\u003c/span\u003e\u003c/button\u003e\r\n            \u003c/div\u003e\r\n            \u003ctable id\u003d\"files-table\"\u003e\r\n                \u003cthead\u003e\r\n                \u003ctr\u003e\r\n                    \u003cth data-i18n\u003d\"Name\"\u003eИмя\u003c/th\u003e\r\n                    \u003cth data-i18n\u003d\"Size\"\u003eРазмер\u003c/th\u003e\r\n                    \u003cth data-i18n\u003d\"Date\"\u003eДата\u003c/th\u003e\r\n                \u003c/tr\u003e\r\n                \u003c/thead\u003e\r\n                \u003ctbody id\u003d\"files\"\u003e\u003c/tbody\u003e\r\n            \u003c/table\u003e\r\n        \u003c/div\u003e\r\n    \u003c/div\u003e\r\n    \u003cdiv id\u003d\"loader\" aria-hidden\u003d\"true\"\u003e\r\n        \u003cdiv class\u003d\"spinner-wrap\"\u003e\r\n            \u003cdiv class\u003d\"spinner\"\u003e\u003c/div\u003e\r\n            \u003cspan class\u003d\"spinner-label\" data-i18n\u003d\"Loading...\"\u003eЗагрузка...\u003c/span\u003e\r\n        \u003c/div\u003e\r\n    \u003c/div\u003e\r\n\u003c/div\u003e\r\n\r\n\u003cdiv id\u003d\"toast\" class\u003d\"toast toast-error\" role\u003d\"status\" aria-live\u003d\"polite\" aria-atomic\u003d\"true\"\u003e\u003c/div\u003e\r\n\r\n\u003cdiv id\u003d\"modal\" class\u003d\"modal-bg\" role\u003d\"dialog\" aria-modal\u003d\"true\" aria-labelledby\u003d\"modalTitle\"\u003e\r\n    \u003cdiv class\u003d\"modal\"\u003e\r\n        \u003cdiv id\u003d\"modalTitle\"\u003e\u003c/div\u003e\r\n        \u003cdiv id\u003d\"modalHint\" class\u003d\"modal-hint\"\u003e\u003c/div\u003e\r\n        \u003cinput id\u003d\"modalInput\" type\u003d\"text\" autocomplete\u003d\"off\" /\u003e\r\n        \u003cdiv class\u003d\"modal-actions\"\u003e\r\n            \u003cbutton type\u003d\"button\" class\u003d\"btn btn-ghost\" onclick\u003d\"closeModal()\" data-i18n\u003d\"Cancel\"\u003eОтмена\u003c/button\u003e\r\n            \u003cbutton type\u003d\"button\" class\u003d\"btn btn-primary\" id\u003d\"modalOkBtn\" onclick\u003d\"confirmModal()\"\u003eOK\u003c/button\u003e\r\n        \u003c/div\u003e\r\n    \u003c/div\u003e\r\n\u003c/div\u003e\r\n\r\n\u003cscript\u003e\r\n    let currentPath \u003d \"{lv\u003drootPath}\";\r\n    let selectedItem \u003d null;\r\n    let modalAction \u003d null;\r\n    const API \u003d \"{lv\u003dapiUrl}\";\r\n    const ALLOWED_EXT_RAW \u003d \"{lv\u003dallowedFileExt}\";\r\n    const REQUEST_TIMEOUT_MS \u003d 30000;\r\n    const UPLOAD_TIMEOUT_MS \u003d 180000;\r\n    /* Max. size of file for GET ?cmd\u003dupload (base64 in query); otherwise URL will overflow. */\r\n    const MAX_GET_UPLOAD_BYTES \u003d 45000;\r\n    const CLIPBOARD_KEY \u003d \"md_rfm_clipboard\";\r\n    const CLIPBOARD_LEGACY_PATH \u003d \"md_rfm_move_from\";\r\n    let toastHideTimer \u003d null;\r\n\r\n    const dom \u003d {};\r\n    function byId(id) {\r\n        if (Object.prototype.hasOwnProperty.call(dom, id)) {\r\n            return dom[id];\r\n        }\r\n        dom[id] \u003d document.getElementById(id);\r\n        return dom[id];\r\n    }\r\n\r\n    let I18N_DICT \u003d {};\r\n    try {\r\n        const el \u003d document.getElementById(\"md-i18n-json\");\r\n        const raw \u003d el ? JSON.parse(el.textContent) : null;\r\n        I18N_DICT \u003d raw \u0026\u0026 typeof raw \u003d\u003d\u003d \"object\" \u0026\u0026 !Array.isArray(raw) ? raw : {};\r\n    } catch (e) {\r\n        I18N_DICT \u003d {};\r\n    }\r\n\r\n    let lastListError \u003d null;\r\n\r\n    function pageLangFromMeta() {\r\n        const m \u003d document.querySelector(\u0027meta[name\u003d\"md-page-lang\"]\u0027);\r\n        const c \u003d m \u0026\u0026 m.getAttribute(\"content\");\r\n        const trimmed \u003d c ? String(c).trim() : \"\";\r\n        return trimmed || \"ru\";\r\n    }\r\n\r\n    /**\r\n     * Localized string by key-phrase in English.\r\n     * Placeholders: t(\"...\", { status: \"404\", sec: \"30\" }) substitutes {status}, {sec}.\r\n     */\r\n    function t(key, vars) {\r\n        let s \u003d I18N_DICT[key];\r\n        if (s \u003d\u003d null || s \u003d\u003d\u003d \"\") {\r\n            return key;\r\n        }\r\n        s \u003d String(s);\r\n        if (vars \u0026\u0026 typeof vars \u003d\u003d\u003d \"object\") {\r\n            for (const k in vars) {\r\n                if (Object.prototype.hasOwnProperty.call(vars, k)) {\r\n                    s \u003d s.split(\"{\" + k + \"}\").join(String(vars[k]));\r\n                }\r\n            }\r\n        }\r\n        return s;\r\n    }\r\n\r\n    function updateMobileColLabels() {\r\n        const st \u003d byId(\"i18n-mobile-col-labels\");\r\n        if (!st) {\r\n            return;\r\n        }\r\n        const sizeQ \u003d JSON.stringify(t(\"Size\") + \" \\u00b7 \");\r\n        const dateQ \u003d JSON.stringify(t(\"Date\") + \" \\u00b7 \");\r\n        st.textContent \u003d\r\n            \"@media (max-width: 640px) { \" +\r\n            \"#files-table tbody td:nth-child(2)::before { content: \" +\r\n            sizeQ +\r\n            \"; } \" +\r\n            \"#files-table tbody td:nth-child(3)::before { content: \" +\r\n            dateQ +\r\n            \"; } \" +\r\n            \"}\";\r\n    }\r\n\r\n    const I18N_ATTR_HANDLERS \u003d [\r\n        [\"data-i18n\", (el, v) \u003d\u003e {\r\n            el.textContent \u003d v;\r\n        }],\r\n        [\"data-i18n-title\", (el, v) \u003d\u003e {\r\n            el.setAttribute(\"title\", v);\r\n        }],\r\n        [\"data-i18n-placeholder\", (el, v) \u003d\u003e {\r\n            el.setAttribute(\"placeholder\", v);\r\n        }],\r\n        [\"data-i18n-aria\", (el, v) \u003d\u003e {\r\n            el.setAttribute(\"aria-label\", v);\r\n        }],\r\n    ];\r\n\r\n    function applyStaticI18n() {\r\n        document.documentElement.setAttribute(\"lang\", pageLangFromMeta());\r\n        for (const [attr, fn] of I18N_ATTR_HANDLERS) {\r\n            document.querySelectorAll(\"[\" + attr + \"]\").forEach((el) \u003d\u003e {\r\n                const k \u003d el.getAttribute(attr);\r\n                if (k) {\r\n                    fn(el, t(k));\r\n                }\r\n            });\r\n        }\r\n        updateMobileColLabels();\r\n        if (lastListError) {\r\n            const text \u003d byId(\"list-error-text\");\r\n            if (text) {\r\n                text.innerHTML \u003d listErrorHtml(lastListError);\r\n            }\r\n        }\r\n    }\r\n\r\n    function pathBaseName(fullPath) {\r\n        const parts \u003d String(fullPath).replace(/\\/+$/, \"\").split(\"/\").filter(Boolean);\r\n        return parts.length ? parts[parts.length - 1] : \"\";\r\n    }\r\n\r\n    function parentDirOf(fullPath) {\r\n        const pathStr \u003d String(fullPath).replace(/\\/+$/, \"\");\r\n        const idx \u003d pathStr.lastIndexOf(\"/\");\r\n        if (idx \u003c\u003d 0) {\r\n            return \"/\";\r\n        }\r\n        return pathStr.slice(0, idx + 1);\r\n    }\r\n\r\n    function joinDirAndName(dir, name) {\r\n        let d \u003d dir.endsWith(\"/\") ? dir : dir + \"/\";\r\n        if (!d.startsWith(\"/\")) {\r\n            d \u003d \"/\" + d;\r\n        }\r\n        return d + name;\r\n    }\r\n\r\n    /**\r\n     * Triple full / dir / file + isDirectory for API.\r\n     * @param {string} absPath path from file system / API list\r\n     * @param {boolean} isDirectory object - directory\r\n     * @returns {{ full: string, dir: string, file: string, isDirectory: boolean }}\r\n     */\r\n    function pathTripleFromFs(absPath, isDirectory) {\r\n        const isDir \u003d !!isDirectory;\r\n        let s \u003d String(absPath).trim();\r\n        if (!s.startsWith(\"/\")) {\r\n            s \u003d \"/\" + s;\r\n        }\r\n        if (isDir) {\r\n            const core \u003d s.replace(/\\/+$/, \"\") || \"/\";\r\n            if (core \u003d\u003d\u003d \"/\") {\r\n                return {full: \"/\", dir: \"/\", file: \"\", isDirectory: true};\r\n            }\r\n            const file \u003d pathBaseName(core);\r\n            const dir \u003d parentDirOf(core);\r\n            return {full: core + \"/\", dir, file, isDirectory: true};\r\n        }\r\n        const core \u003d s.replace(/\\/+$/, \"\");\r\n        if (core \u003d\u003d\u003d \"\" || core \u003d\u003d\u003d \"/\") {\r\n            return {full: \"/\", dir: \"/\", file: \"\", isDirectory: false};\r\n        }\r\n        const file \u003d pathBaseName(core);\r\n        const dir \u003d parentDirOf(core);\r\n        return {full: core, dir, file, isDirectory: false};\r\n    }\r\n\r\n    function typeParam(isDirectory) {\r\n        return isDirectory ? \"dir\" : \"file\";\r\n    }\r\n\r\n    function queryFromTriple(triple) {\r\n        const p \u003d new URLSearchParams();\r\n        p.set(\"type\", typeParam(triple.isDirectory \u003d\u003d\u003d true));\r\n        p.set(\"full\", triple.full);\r\n        p.set(\"dir\", triple.dir);\r\n        p.set(\"file\", triple.file);\r\n        return p.toString();\r\n    }\r\n\r\n    function queryFromSrcDst(src, dst) {\r\n        const p \u003d new URLSearchParams();\r\n        p.set(\"type\", typeParam(src.isDirectory \u003d\u003d\u003d true));\r\n        p.set(\"srcFull\", src.full);\r\n        p.set(\"srcDir\", src.dir);\r\n        p.set(\"srcFile\", src.file);\r\n        p.set(\"dstFull\", dst.full);\r\n        p.set(\"dstDir\", dst.dir);\r\n        p.set(\"dstFile\", dst.file);\r\n        return p.toString();\r\n    }\r\n\r\n    function httpError(status) {\r\n        const e \u003d new Error(\"http\");\r\n        e.code \u003d \"HTTP\";\r\n        e.status \u003d status;\r\n        return e;\r\n    }\r\n\r\n    function readCookie(name) {\r\n        try {\r\n            const m \u003d document.cookie.match(new RegExp(\"(?:^|; )\" + name.replace(/[.*+?^${}()|[\\]\\\\]/g, \"\\\\$\u0026\") + \"\u003d([^;]*)\"));\r\n            return m ? decodeURIComponent(m[1]) : \"\";\r\n        } catch (e) {\r\n            return \"\";\r\n        }\r\n    }\r\n\r\n    function clearCookie(name) {\r\n        document.cookie \u003d name + \"\u003d;path\u003d/;max-age\u003d0;SameSite\u003dLax\";\r\n    }\r\n\r\n    function normalizeNavPath(s) {\r\n        let p \u003d String(s).trim();\r\n        if (!p) {\r\n            p \u003d \"/\";\r\n        }\r\n        if (!p.startsWith(\"/\")) {\r\n            p \u003d \"/\" + p;\r\n        }\r\n        if (p.length \u003e 1 \u0026\u0026 !p.endsWith(\"/\")) {\r\n            p +\u003d \"/\";\r\n        }\r\n        return p;\r\n    }\r\n\r\n    /* Normalized start path - navigation above it is prohibited. */\r\n    const NAV_ROOT \u003d normalizeNavPath(currentPath);\r\n    currentPath \u003d NAV_ROOT;\r\n\r\n    /**\r\n     * Limits the path to the limits of NAV_ROOT (cannot go to / or to neighboring directories).\r\n     * If NAV_ROOT is \"/\", there are no restrictions.\r\n     */\r\n    function clampNavPath(path) {\r\n        const n \u003d normalizeNavPath(path);\r\n        const rootN \u003d normalizeNavPath(NAV_ROOT);\r\n        if (rootN \u003d\u003d\u003d \"/\") {\r\n            return n;\r\n        }\r\n        const rSlash \u003d rootN.endsWith(\"/\") ? rootN : rootN + \"/\";\r\n        const nSlash \u003d n.endsWith(\"/\") ? n : n + \"/\";\r\n        if (nSlash \u003d\u003d\u003d rSlash || nSlash.startsWith(rSlash)) {\r\n            return n;\r\n        }\r\n        return rootN;\r\n    }\r\n\r\n    function updateNavUpButtonState() {\r\n        const btn \u003d byId(\"nav-up-btn\");\r\n        if (!btn) {\r\n            return;\r\n        }\r\n        const atRoot \u003d normalizeNavPath(currentPath) \u003d\u003d\u003d normalizeNavPath(NAV_ROOT);\r\n        btn.disabled \u003d atRoot;\r\n        btn.setAttribute(\"aria-disabled\", atRoot ? \"true\" : \"false\");\r\n    }\r\n\r\n    function syncPathFieldFromState() {\r\n        const el \u003d byId(\"path\");\r\n        if (el \u0026\u0026 document.activeElement !\u003d\u003d el) {\r\n            el.value \u003d currentPath;\r\n        }\r\n    }\r\n\r\n    function applyPathNavigation() {\r\n        const el \u003d byId(\"path\");\r\n        if (!el) {\r\n            return;\r\n        }\r\n        currentPath \u003d clampNavPath(normalizeNavPath(el.value));\r\n        el.value \u003d currentPath;\r\n        el.blur();\r\n        updateNavUpButtonState();\r\n        render();\r\n    }\r\n\r\n    /* Extension only if dot not in the beginning of the name (not hidden `.name`). */\r\n    function preservedExtension(baseName) {\r\n        const b \u003d String(baseName);\r\n        const d \u003d b.lastIndexOf(\".\");\r\n        if (d \u003c\u003d 0) {\r\n            return \"\";\r\n        }\r\n        return b.slice(d);\r\n    }\r\n\r\n    function buildRenameNewBase(userInput, oldBaseName) {\r\n        const u \u003d String(userInput).trim();\r\n        if (!u) {\r\n            return oldBaseName;\r\n        }\r\n        const ext \u003d preservedExtension(oldBaseName);\r\n        if (!ext) {\r\n            return u;\r\n        }\r\n        if (u.toLowerCase().endsWith(ext.toLowerCase())) {\r\n            return u;\r\n        }\r\n        return u + ext;\r\n    }\r\n\r\n    function isDotHiddenName(fullPath) {\r\n        const base \u003d pathBaseName(fullPath);\r\n        return base.startsWith(\".\");\r\n    }\r\n\r\n    function parseClipboardJson(raw) {\r\n        if (raw \u003d\u003d null || String(raw).trim() \u003d\u003d\u003d \"\") {\r\n            return null;\r\n        }\r\n        try {\r\n            const o \u003d JSON.parse(raw);\r\n            const p \u003d typeof o.path \u003d\u003d\u003d \"string\" ? o.path.trim() : \"\";\r\n            if (!p || (o.mode !\u003d\u003d \"move\" \u0026\u0026 o.mode !\u003d\u003d \"copy\")) {\r\n                return null;\r\n            }\r\n            const isDir \u003d\r\n                typeof o.isDir \u003d\u003d\u003d \"boolean\"\r\n                    ? o.isDir\r\n                    : p.replace(/\\/+$/, \"\").length \u003e 0 \u0026\u0026 p.endsWith(\"/\");\r\n            return {mode: o.mode, path: p, isDir};\r\n        } catch (e) {\r\n        }\r\n        return null;\r\n    }\r\n\r\n    function getClipboard() {\r\n        try {\r\n            const rawLs \u003d localStorage.getItem(CLIPBOARD_KEY);\r\n            const parsed \u003d parseClipboardJson(rawLs);\r\n            if (parsed) {\r\n                return parsed;\r\n            }\r\n            if (rawLs !\u003d null \u0026\u0026 rawLs !\u003d\u003d \"\") {\r\n                localStorage.removeItem(CLIPBOARD_KEY);\r\n            }\r\n        } catch (e) {\r\n        }\r\n        try {\r\n            const leg \u003d localStorage.getItem(CLIPBOARD_LEGACY_PATH);\r\n            const legTrim \u003d leg ? String(leg).trim() : \"\";\r\n            if (legTrim) {\r\n                const o \u003d {mode: \"move\", path: legTrim, isDir: legTrim.endsWith(\"/\")};\r\n                setClipboard(o.mode, o.path, o.isDir);\r\n                localStorage.removeItem(CLIPBOARD_LEGACY_PATH);\r\n                return o;\r\n            }\r\n            if (leg) {\r\n                localStorage.removeItem(CLIPBOARD_LEGACY_PATH);\r\n            }\r\n        } catch (e2) {\r\n        }\r\n        try {\r\n            const rawCk \u003d readCookie(CLIPBOARD_KEY);\r\n            if (rawCk) {\r\n                const parsed \u003d parseClipboardJson(rawCk);\r\n                if (parsed) {\r\n                    return parsed;\r\n                }\r\n                clearCookie(CLIPBOARD_KEY);\r\n            }\r\n        } catch (e3) {\r\n        }\r\n        try {\r\n            const rawLegacy \u003d readCookie(CLIPBOARD_LEGACY_PATH).trim();\r\n            if (rawLegacy) {\r\n                clearCookie(CLIPBOARD_LEGACY_PATH);\r\n                const o \u003d {mode: \"move\", path: rawLegacy, isDir: rawLegacy.endsWith(\"/\")};\r\n                setClipboard(o.mode, o.path, o.isDir);\r\n                return o;\r\n            }\r\n        } catch (e4) {\r\n        }\r\n        return null;\r\n    }\r\n\r\n    function setClipboard(mode, path, isDir) {\r\n        const raw \u003d JSON.stringify({mode, path, isDir: !!isDir});\r\n        try {\r\n            localStorage.setItem(CLIPBOARD_KEY, raw);\r\n        } catch (e) {\r\n        }\r\n        try {\r\n            document.cookie \u003d\r\n                CLIPBOARD_KEY + \"\u003d\" + encodeURIComponent(raw) + \";path\u003d/;max-age\u003d86400;SameSite\u003dLax\";\r\n        } catch (e2) {\r\n        }\r\n    }\r\n\r\n    function clearClipboard() {\r\n        try {\r\n            localStorage.removeItem(CLIPBOARD_KEY);\r\n        } catch (e) {\r\n        }\r\n        try {\r\n            clearCookie(CLIPBOARD_KEY);\r\n        } catch (e2) {\r\n        }\r\n        try {\r\n            localStorage.removeItem(CLIPBOARD_LEGACY_PATH);\r\n        } catch (e3) {\r\n        }\r\n        try {\r\n            clearCookie(CLIPBOARD_LEGACY_PATH);\r\n        } catch (e4) {\r\n        }\r\n    }\r\n\r\n    function updateClipboardUi() {\r\n        const clip \u003d getClipboard();\r\n        const pasteBtn \u003d byId(\"clip-paste-btn\");\r\n        const cancelBtn \u003d byId(\"clip-cancel-btn\");\r\n        const hint \u003d byId(\"clip-buffer-hint\");\r\n        const hasClip \u003d !!(clip \u0026\u0026 typeof clip.path \u003d\u003d\u003d \"string\" \u0026\u0026 clip.path.trim());\r\n        if (!hasClip) {\r\n            pasteBtn.setAttribute(\"hidden\", \"\");\r\n            cancelBtn.setAttribute(\"hidden\", \"\");\r\n            hint.hidden \u003d true;\r\n            hint.innerHTML \u003d \"\";\r\n            return;\r\n        }\r\n        pasteBtn.removeAttribute(\"hidden\");\r\n        cancelBtn.removeAttribute(\"hidden\");\r\n        hint.hidden \u003d false;\r\n        const short \u003d pathBaseName(clip.path) || clip.path;\r\n        const modeLabel \u003d clip.mode \u003d\u003d\u003d \"copy\" ? t(\"copy\") : t(\"move\");\r\n        hint.innerHTML \u003d\r\n            \"\u003cstrong\u003e\" +\r\n            escapeHtml(t(\"In buffer\")) +\r\n            \" (\" +\r\n            escapeHtml(modeLabel) +\r\n            \"):\u003c/strong\u003e \" +\r\n            escapeHtml(short) +\r\n            \" — \" +\r\n            (clip.mode \u003d\u003d\u003d \"copy\"\r\n                ? escapeHtml(t(\"paste into target folders; clear the buffer with Cancel.\"))\r\n                : escapeHtml(t(\"open the destination folder and tap Paste here.\")));\r\n        pasteBtn.title \u003d\r\n            clip.mode \u003d\u003d\u003d \"copy\" ? t(\"Copy into current folder (buffer stays)\") : t(\"Move into current folder\");\r\n        cancelBtn.title \u003d t(\"Clear buffer ({mode})\", {mode: modeLabel});\r\n    }\r\n\r\n    function escapeHtml(s) {\r\n        return String(s)\r\n            .replace(/\u0026/g, \"\u0026amp;\")\r\n            .replace(/\u003c/g, \"\u0026lt;\")\r\n            .replace(/\u003e/g, \"\u0026gt;\")\r\n            .replace(/\"/g, \"\u0026quot;\");\r\n    }\r\n\r\n    function listErrorBlock(strongKey, bodyKey, bodyVars) {\r\n        return (\r\n            \"\u003cstrong\u003e\" +\r\n            escapeHtml(t(strongKey)) +\r\n            \"\u003c/strong\u003e\" +\r\n            escapeHtml(bodyVars ? t(bodyKey, bodyVars) : t(bodyKey))\r\n        );\r\n    }\r\n\r\n    function startMoveFrom(fullPath, isDirectory) {\r\n        closeAllRowMenus();\r\n        setClipboard(\"move\", fullPath, !!isDirectory);\r\n        updateClipboardUi();\r\n        showToast(t(\"Move: open the destination folder and tap Paste here.\"), \"ok\");\r\n    }\r\n\r\n    function startCopyFrom(fullPath, isDirectory) {\r\n        closeAllRowMenus();\r\n        setClipboard(\"copy\", fullPath, !!isDirectory);\r\n        updateClipboardUi();\r\n        showToast(t(\"Copy: pick a folder and Paste here (repeatable).\"), \"ok\");\r\n    }\r\n\r\n    async function pasteClipboardIntoCurrentFolder() {\r\n        const clip \u003d getClipboard();\r\n        if (!clip || !clip.path) {\r\n            return;\r\n        }\r\n        const from \u003d clip.path;\r\n        const clipIsDir \u003d !!clip.isDir;\r\n        const name \u003d pathBaseName(from.replace(/\\/+$/, \"\")) || \"\";\r\n        if (!name) {\r\n            showToast(t(\"Invalid path in buffer.\"), \"error\");\r\n            return;\r\n        }\r\n        let dstFull \u003d joinDirAndName(currentPath, name);\r\n        if (clipIsDir) {\r\n            dstFull \u003d dstFull.replace(/\\/+$/, \"\") + \"/\";\r\n        }\r\n        const srcT \u003d pathTripleFromFs(from, clipIsDir);\r\n        const dstT \u003d pathTripleFromFs(dstFull, clipIsDir);\r\n        if (srcT.full \u003d\u003d\u003d dstT.full) {\r\n            showToast(t(\"Item is already in this folder.\"), \"error\");\r\n            return;\r\n        }\r\n        const cmd \u003d clip.mode \u003d\u003d\u003d \"copy\" ? \"copy\" : \"move\";\r\n        try {\r\n            loader(true);\r\n            const res \u003d await fetchChecked(API + \"?cmd\u003d\" + cmd + \"\u0026\" + queryFromSrcDst(srcT, dstT));\r\n            if (!res.ok) {\r\n                throw httpError(res.status);\r\n            }\r\n            if (clip.mode \u003d\u003d\u003d \"move\") {\r\n                clearClipboard();\r\n            }\r\n            updateClipboardUi();\r\n            showToast(clip.mode \u003d\u003d\u003d \"copy\" ? t(\"Copied\") : t(\"Moved\"), \"ok\");\r\n            await render();\r\n        } catch (err) {\r\n            loader(false);\r\n            showToast(actionErrorText(err), \"error\");\r\n        }\r\n    }\r\n\r\n    function cancelClipboard() {\r\n        clearClipboard();\r\n        updateClipboardUi();\r\n    }\r\n\r\n    async function fetchWithTimeout(url, options \u003d {}, timeoutMs \u003d REQUEST_TIMEOUT_MS) {\r\n        const controller \u003d new AbortController();\r\n        const timeoutId \u003d setTimeout(() \u003d\u003e controller.abort(), timeoutMs);\r\n        try {\r\n            const res \u003d await fetch(url, {...options, signal: controller.signal});\r\n            clearTimeout(timeoutId);\r\n            return res;\r\n        } catch (err) {\r\n            clearTimeout(timeoutId);\r\n            throw err;\r\n        }\r\n    }\r\n\r\n    async function fetchChecked(url, options \u003d {}, timeoutMs \u003d REQUEST_TIMEOUT_MS) {\r\n        try {\r\n            return await fetchWithTimeout(url, options, timeoutMs);\r\n        } catch (err) {\r\n            if (err \u0026\u0026 err.name \u003d\u003d\u003d \"AbortError\") {\r\n                const timeoutErr \u003d new Error(\"timeout\");\r\n                timeoutErr.code \u003d \"TIMEOUT\";\r\n                throw timeoutErr;\r\n            }\r\n            const netErr \u003d new Error(\"network\");\r\n            netErr.code \u003d \"NETWORK\";\r\n            throw netErr;\r\n        }\r\n    }\r\n\r\n    function listErrorHtml(err) {\r\n        const sec \u003d String(REQUEST_TIMEOUT_MS / 1000);\r\n        if (err \u0026\u0026 err.code \u003d\u003d\u003d \"INVALID_JSON\") {\r\n            return listErrorBlock(\r\n                \"Unexpected server response\",\r\n                \"Expected a JSON list. Check the URL and the MacroDroid HTTP server action.\",\r\n            );\r\n        }\r\n        if (err \u0026\u0026 err.code \u003d\u003d\u003d \"TIMEOUT\") {\r\n            return listErrorBlock(\r\n                \"Request timed out\",\r\n                \"No response within {sec} s. Ensure the MacroDroid HTTP server is running and the template URL matches the device.\",\r\n                {sec},\r\n            );\r\n        }\r\n        if (err \u0026\u0026 err.code \u003d\u003d\u003d \"HTTP\") {\r\n            const st \u003d err.status !\u003d null ? String(err.status) : \"?\";\r\n            return listErrorBlock(\r\n                \"Server error\",\r\n                \"HTTP status: {status}. Try refreshing or restarting the MacroDroid macro.\",\r\n                {status: st},\r\n            );\r\n        }\r\n        if (err \u0026\u0026 err.code \u003d\u003d\u003d \"NETWORK\") {\r\n            return listErrorBlock(\r\n                \"No connection\",\r\n                \"Could not reach the server. Check Wi‑Fi / hotspot and that the phone is reachable on this network.\",\r\n            );\r\n        }\r\n        return listErrorBlock(\"Could not load the list\", \"Tap Retry or restart the MacroDroid HTTP server.\");\r\n    }\r\n\r\n    function actionErrorText(err) {\r\n        if (err \u0026\u0026 err.code \u003d\u003d\u003d \"TIMEOUT\") {\r\n            return t(\"Timed out — the operation may not have completed.\");\r\n        }\r\n        if (err \u0026\u0026 err.code \u003d\u003d\u003d \"HTTP\") {\r\n            const st \u003d err.status !\u003d null ? String(err.status) : \"?\";\r\n            return t(\"Server rejected the operation (status {status}).\", {status: st});\r\n        }\r\n        if (err \u0026\u0026 err.code \u003d\u003d\u003d \"NETWORK\") {\r\n            return t(\"No server connection. Check the network and MacroDroid.\");\r\n        }\r\n        return t(\"Operation failed. Try again.\");\r\n    }\r\n\r\n    function showListError(err) {\r\n        lastListError \u003d err;\r\n        const panel \u003d byId(\"list-error\");\r\n        const text \u003d byId(\"list-error-text\");\r\n        const table \u003d byId(\"files-table\");\r\n        text.innerHTML \u003d listErrorHtml(err);\r\n        panel.classList.add(\"is-visible\");\r\n        panel.removeAttribute(\"hidden\");\r\n        table.classList.add(\"is-hidden\");\r\n        byId(\"files\").innerHTML \u003d \"\";\r\n        updateClipboardUi();\r\n    }\r\n\r\n    function clearListError() {\r\n        lastListError \u003d null;\r\n        const panel \u003d byId(\"list-error\");\r\n        const table \u003d byId(\"files-table\");\r\n        panel.classList.remove(\"is-visible\");\r\n        panel.setAttribute(\"hidden\", \"true\");\r\n        table.classList.remove(\"is-hidden\");\r\n    }\r\n\r\n    function showToast(message, variant) {\r\n        const el \u003d byId(\"toast\");\r\n        el.textContent \u003d message;\r\n        el.classList.remove(\"toast-error\", \"toast-ok\");\r\n        el.classList.add(variant \u003d\u003d\u003d \"ok\" ? \"toast-ok\" : \"toast-error\");\r\n        el.classList.add(\"is-visible\");\r\n        if (toastHideTimer) {\r\n            clearTimeout(toastHideTimer);\r\n        }\r\n        toastHideTimer \u003d setTimeout(() \u003d\u003e {\r\n            el.classList.remove(\"is-visible\");\r\n        }, 4500);\r\n    }\r\n\r\n    async function fetchFiles() {\r\n        const listTriple \u003d pathTripleFromFs(currentPath, true);\r\n        const url \u003d API + \"?cmd\u003dlist\u0026\" + queryFromTriple(listTriple);\r\n        const res \u003d await fetchChecked(url);\r\n        if (!res.ok) {\r\n            throw httpError(res.status);\r\n        }\r\n        const text \u003d await res.text();\r\n        try {\r\n            return JSON.parse(text);\r\n        } catch {\r\n            const e \u003d new Error(\"invalid json\");\r\n            e.code \u003d \"INVALID_JSON\";\r\n            throw e;\r\n        }\r\n    }\r\n\r\n    function formatSize(b) {\r\n        if (b \u003c 1024) {\r\n            return b + t(\" B\");\r\n        }\r\n        if (b \u003c 1e6) {\r\n            return (b / 1024).toFixed(1) + t(\" KB\");\r\n        }\r\n        return (b / 1e6).toFixed(1) + t(\" MB\");\r\n    }\r\n\r\n    function closeAllRowMenus() {\r\n        document.querySelectorAll(\".row-menu-dropdown.is-open\").forEach((menu) \u003d\u003e {\r\n            menu.classList.remove(\"is-open\");\r\n            menu.hidden \u003d true;\r\n            menu.style.top \u003d \"\";\r\n            menu.style.right \u003d \"\";\r\n            menu.style.left \u003d \"\";\r\n            menu.style.maxHeight \u003d \"\";\r\n            menu.style.overflowY \u003d \"\";\r\n        });\r\n        document.querySelectorAll(\".row-menu-trigger\").forEach((btn) \u003d\u003e btn.setAttribute(\"aria-expanded\", \"false\"));\r\n    }\r\n\r\n    function openRowMenu(trigger, menu) {\r\n        closeAllRowMenus();\r\n        menu.hidden \u003d false;\r\n        menu.classList.add(\"is-open\");\r\n        trigger.setAttribute(\"aria-expanded\", \"true\");\r\n        const r \u003d trigger.getBoundingClientRect();\r\n        const pad \u003d 8;\r\n        let menuTop \u003d r.bottom + 6;\r\n        menu.style.right \u003d window.innerWidth - r.right + \"px\";\r\n        menu.style.left \u003d \"auto\";\r\n        menu.style.top \u003d menuTop + \"px\";\r\n        menu.style.maxHeight \u003d \"min(280px, calc(100dvh - \" + (menuTop + pad) + \"px))\";\r\n        menu.style.overflowY \u003d \"auto\";\r\n        requestAnimationFrame(() \u003d\u003e {\r\n            const br \u003d menu.getBoundingClientRect();\r\n            if (br.bottom \u003e window.innerHeight - pad) {\r\n                const h \u003d br.height;\r\n                menuTop \u003d Math.max(pad, r.top - h - 6);\r\n                menu.style.top \u003d menuTop + \"px\";\r\n                menu.style.maxHeight \u003d \"min(280px, calc(100dvh - \" + (menuTop + pad) + \"px))\";\r\n            }\r\n        });\r\n    }\r\n\r\n    function toggleRowMenu(trigger, menu, e) {\r\n        e.stopPropagation();\r\n        if (menu.classList.contains(\"is-open\")) {\r\n            closeAllRowMenus();\r\n        } else {\r\n            openRowMenu(trigger, menu);\r\n        }\r\n    }\r\n\r\n    function buildFileRowActions(item) {\r\n        const tx \u003d {\r\n            download: t(\"Download\"),\r\n            rename: t(\"Rename\"),\r\n            moveBuf: t(\"To buffer — then open folder and Paste\"),\r\n            copyBuf: t(\"To copy buffer\"),\r\n            del: t(\"Delete\"),\r\n            move: t(\"Move\"),\r\n            copy: t(\"Copy\"),\r\n            actions: t(\"Actions\"),\r\n        };\r\n        const desk \u003d document.createElement(\"div\");\r\n        desk.className \u003d \"actions-desktop\";\r\n\r\n        function addDesktopAction(opts) {\r\n            const div \u003d document.createElement(\"div\");\r\n            div.className \u003d \"action-btn\" + (opts.danger ? \" danger\" : \"\");\r\n            div.setAttribute(\"role\", \"button\");\r\n            div.tabIndex \u003d 0;\r\n            div.title \u003d opts.title;\r\n            div.setAttribute(\"aria-label\", opts.ariaLabel);\r\n            div.textContent \u003d opts.glyph;\r\n            const run \u003d opts.run;\r\n            div.addEventListener(\"click\", (ev) \u003d\u003e {\r\n                ev.stopPropagation();\r\n                run();\r\n            });\r\n            div.addEventListener(\"keydown\", (ev) \u003d\u003e {\r\n                if (ev.key \u003d\u003d\u003d \"Enter\" || ev.key \u003d\u003d\u003d \" \") {\r\n                    ev.preventDefault();\r\n                    ev.stopPropagation();\r\n                    run();\r\n                }\r\n            });\r\n            desk.appendChild(div);\r\n        }\r\n\r\n        const path \u003d item.fullPath;\r\n        const isDir \u003d item.isDirectory;\r\n\r\n        addDesktopAction({\r\n            title: tx.download,\r\n            ariaLabel: tx.download,\r\n            glyph: \"⬇\",\r\n            run: () \u003d\u003e downloadItem(path),\r\n        });\r\n        addDesktopAction({\r\n            title: tx.rename,\r\n            ariaLabel: tx.rename,\r\n            glyph: \"✏\",\r\n            run: () \u003d\u003e {\r\n                selectItem(path, isDir);\r\n                openModal(\"rename\");\r\n            },\r\n        });\r\n        addDesktopAction({\r\n            title: tx.moveBuf,\r\n            ariaLabel: tx.move,\r\n            glyph: \"📂\",\r\n            run: () \u003d\u003e startMoveFrom(path, isDir),\r\n        });\r\n        addDesktopAction({\r\n            title: tx.copyBuf,\r\n            ariaLabel: tx.copy,\r\n            glyph: \"📑\",\r\n            run: () \u003d\u003e startCopyFrom(path, isDir),\r\n        });\r\n        addDesktopAction({\r\n            title: tx.del,\r\n            ariaLabel: tx.del,\r\n            glyph: \"🗑\",\r\n            danger: true,\r\n            run: () \u003d\u003e {\r\n                selectItem(path, isDir);\r\n                openModal(\"delete\");\r\n            },\r\n        });\r\n\r\n        const mob \u003d document.createElement(\"div\");\r\n        mob.className \u003d \"actions-mobile row-menu-wrap\";\r\n        const trigger \u003d document.createElement(\"button\");\r\n        trigger.type \u003d \"button\";\r\n        trigger.className \u003d \"action-btn row-menu-trigger\";\r\n        trigger.setAttribute(\"aria-label\", tx.actions);\r\n        trigger.setAttribute(\"aria-expanded\", \"false\");\r\n        trigger.setAttribute(\"aria-haspopup\", \"true\");\r\n        trigger.textContent \u003d \"⋮\";\r\n        const menu \u003d document.createElement(\"div\");\r\n        menu.className \u003d \"row-menu-dropdown\";\r\n        menu.hidden \u003d true;\r\n        menu.setAttribute(\"role\", \"menu\");\r\n\r\n        function addMenuItem(label, isDanger, fn) {\r\n            const b \u003d document.createElement(\"button\");\r\n            b.type \u003d \"button\";\r\n            b.className \u003d \"row-menu-item\" + (isDanger ? \" is-danger\" : \"\");\r\n            b.setAttribute(\"role\", \"menuitem\");\r\n            b.textContent \u003d label;\r\n            b.addEventListener(\"click\", (ev) \u003d\u003e {\r\n                ev.stopPropagation();\r\n                closeAllRowMenus();\r\n                fn();\r\n            });\r\n            menu.appendChild(b);\r\n        }\r\n\r\n        addMenuItem(tx.download, false, () \u003d\u003e downloadItem(item.fullPath));\r\n        addMenuItem(tx.rename, false, () \u003d\u003e {\r\n            selectItem(item.fullPath, item.isDirectory);\r\n            openModal(\"rename\");\r\n        });\r\n        addMenuItem(tx.move, false, () \u003d\u003e startMoveFrom(item.fullPath, item.isDirectory));\r\n        addMenuItem(tx.copy, false, () \u003d\u003e startCopyFrom(item.fullPath, item.isDirectory));\r\n        addMenuItem(tx.del, true, () \u003d\u003e {\r\n            selectItem(item.fullPath, item.isDirectory);\r\n            openModal(\"delete\");\r\n        });\r\n\r\n        trigger.addEventListener(\"click\", (ev) \u003d\u003e toggleRowMenu(trigger, menu, ev));\r\n\r\n        mob.appendChild(trigger);\r\n        mob.appendChild(menu);\r\n        return {desk, mob};\r\n    }\r\n\r\n    function parseAllowedExtensions(raw) {\r\n        if (raw \u003d\u003d null || String(raw).trim() \u003d\u003d\u003d \"\") {\r\n            return [];\r\n        }\r\n        return String(raw)\r\n            .split(/[,;|\\s]+/)\r\n            .map((s) \u003d\u003e s.trim().toLowerCase())\r\n            .filter(Boolean)\r\n            .map((s) \u003d\u003e {\r\n                const noStar \u003d s.replace(/^\\*\\./, \".\");\r\n                return noStar.startsWith(\".\") ? noStar : \".\" + noStar;\r\n            });\r\n    }\r\n\r\n    function getAllowedExtensionsList() {\r\n        return parseAllowedExtensions(ALLOWED_EXT_RAW);\r\n    }\r\n\r\n    function isFileExtensionAllowed(fileName, extList) {\r\n        if (extList.length \u003d\u003d\u003d 0) {\r\n            return true;\r\n        }\r\n        const dot \u003d fileName.lastIndexOf(\".\");\r\n        if (dot \u003c 0) {\r\n            return false;\r\n        }\r\n        const ext \u003d fileName.slice(dot).toLowerCase();\r\n        return extList.includes(ext);\r\n    }\r\n\r\n    function applyUploadHint() {\r\n        const hint \u003d byId(\"upload-hint\");\r\n        const list \u003d getAllowedExtensionsList();\r\n        if (list.length \u003d\u003d\u003d 0) {\r\n            hint.hidden \u003d true;\r\n            hint.textContent \u003d \"\";\r\n            return;\r\n        }\r\n        hint.hidden \u003d false;\r\n        hint.innerHTML \u003d \"\u003cstrong\u003e\" + escapeHtml(t(\"Upload:\")) + \"\u003c/strong\u003e \" + escapeHtml(list.join(\", \"));\r\n    }\r\n\r\n    function applyUploadInputFilters() {\r\n        const input \u003d byId(\"upload-input\");\r\n        const list \u003d getAllowedExtensionsList();\r\n        if (list.length \u003e 0) {\r\n            input.setAttribute(\"accept\", list.join(\",\"));\r\n        } else {\r\n            input.removeAttribute(\"accept\");\r\n        }\r\n    }\r\n\r\n    async function runUploads(fileList) {\r\n        const files \u003d fileList ? Array.from(fileList) : [];\r\n        if (files.length \u003d\u003d\u003d 0) {\r\n            return;\r\n        }\r\n\r\n        loader(true);\r\n        let ok \u003d 0;\r\n\r\n        for (const file of files) {\r\n            try {\r\n                const uploadTriple \u003d pathTripleFromFs(joinDirAndName(currentPath, file.name), false);\r\n                const url \u003d API + \"/upload?cmd\u003dupload\u0026\" + queryFromTriple(uploadTriple);\r\n                const res \u003d await fetchChecked(\r\n                    url,\r\n                    {\r\n                        method: \"POST\",\r\n                        headers: {\r\n                            \"Content-Type\": \"application/octet-stream\",\r\n                            \"X-Filename\": encodeURIComponent(file.name),\r\n                        },\r\n                        body: file,\r\n                    },\r\n                    UPLOAD_TIMEOUT_MS,\r\n                );\r\n                if (!res.ok) {\r\n                    throw httpError(res.status);\r\n                }\r\n                ok++;\r\n            } catch (err) {\r\n                showToast(file.name + \": \" + actionErrorText(err), \"error\");\r\n            }\r\n        }\r\n\r\n        if (ok \u003e 0) {\r\n            showToast(ok \u003d\u003d\u003d 1 ? t(\"File uploaded\") : t(\"Uploaded files: {count}\", {count: String(ok)}), \"ok\");\r\n        }\r\n\r\n        await render();\r\n    }\r\n\r\n    async function render() {\r\n        loader(true);\r\n        clearListError();\r\n        syncPathFieldFromState();\r\n        const container \u003d byId(\"files\");\r\n\r\n        let data;\r\n        try {\r\n            data \u003d await fetchFiles();\r\n        } catch (err) {\r\n            loader(false);\r\n            syncPathFieldFromState();\r\n            showListError(err);\r\n            updateNavUpButtonState();\r\n            return;\r\n        }\r\n\r\n        const entries \u003d Object.values(data);\r\n        container.innerHTML \u003d \"\";\r\n\r\n        entries.sort((a, b) \u003d\u003e {\r\n            if (a.isDirectory !\u003d\u003d b.isDirectory) {\r\n                return a.isDirectory ? -1 : 1;\r\n            }\r\n            return a.fullPath.localeCompare(b.fullPath);\r\n        });\r\n\r\n        entries.filter((item) \u003d\u003e !isDotHiddenName(item.fullPath)).forEach((item) \u003d\u003e {\r\n            const tr \u003d document.createElement(\"tr\");\r\n            tr.setAttribute(\"tabindex\", \"0\");\r\n            tr.addEventListener(\"keydown\", (e) \u003d\u003e {\r\n                if (e.key \u003d\u003d\u003d \"Enter\" \u0026\u0026 item.isDirectory) {\r\n                    currentPath \u003d clampNavPath(item.fullPath + \"/\");\r\n                    render();\r\n                }\r\n            });\r\n\r\n            const nameTd \u003d document.createElement(\"td\");\r\n            const sizeTd \u003d document.createElement(\"td\");\r\n            const dateTd \u003d document.createElement(\"td\");\r\n\r\n            const wrap \u003d document.createElement(\"div\");\r\n            wrap.className \u003d \"name\";\r\n\r\n            const icon \u003d document.createElement(\"span\");\r\n            icon.className \u003d \"icon\";\r\n            icon.innerText \u003d item.isDirectory ? \"📁\" : \"📄\";\r\n            icon.setAttribute(\"aria-hidden\", \"true\");\r\n\r\n            const title \u003d document.createElement(\"span\");\r\n            title.className \u003d \"file-title\";\r\n            title.innerText \u003d pathBaseName(item.fullPath);\r\n\r\n            const {desk, mob} \u003d buildFileRowActions(item);\r\n\r\n            wrap.appendChild(icon);\r\n            wrap.appendChild(title);\r\n            wrap.appendChild(desk);\r\n            wrap.appendChild(mob);\r\n            nameTd.appendChild(wrap);\r\n\r\n            sizeTd.innerHTML \u003d `\u003cspan class\u003d\"meta size-pill\"\u003e${formatSize(item.size_bytes)}\u003c/span\u003e`;\r\n            dateTd.innerHTML \u003d `\u003cspan class\u003d\"meta\"\u003e${item.lastModified}\u003c/span\u003e`;\r\n\r\n            tr.onclick \u003d () \u003d\u003e {\r\n                if (item.isDirectory) {\r\n                    currentPath \u003d clampNavPath(item.fullPath + \"/\");\r\n                    render();\r\n                }\r\n            };\r\n\r\n            tr.appendChild(nameTd);\r\n            tr.appendChild(sizeTd);\r\n            tr.appendChild(dateTd);\r\n            container.appendChild(tr);\r\n        });\r\n\r\n        loader(false);\r\n        updateClipboardUi();\r\n        updateNavUpButtonState();\r\n    }\r\n\r\n    function loader(v) {\r\n        const el \u003d byId(\"loader\");\r\n        el.classList.toggle(\"is-visible\", v);\r\n        el.setAttribute(\"aria-hidden\", v ? \"false\" : \"true\");\r\n    }\r\n\r\n    function goUp() {\r\n        let p \u003d currentPath.split(\"/\").filter(Boolean);\r\n        p.pop();\r\n        currentPath \u003d clampNavPath(\"/\" + p.join(\"/\") + (p.length ? \"/\" : \"\"));\r\n        render();\r\n    }\r\n\r\n    function selectItem(fullPath, isDirectory) {\r\n        selectedItem \u003d {fullPath, isDirectory: !!isDirectory};\r\n    }\r\n\r\n    function downloadItem(path) {\r\n        const p \u003d path || selectedItem.fullPath;\r\n        const triple \u003d pathTripleFromFs(p, false);\r\n        window.open(API + \"?cmd\u003ddownload\u0026\" + queryFromTriple(triple));\r\n    }\r\n\r\n    function openModal(type) {\r\n        closeAllRowMenus();\r\n        modalAction \u003d type;\r\n        const modal \u003d byId(\"modal\");\r\n        modal.classList.add(\"is-open\");\r\n\r\n        const title \u003d byId(\"modalTitle\");\r\n        const hint \u003d byId(\"modalHint\");\r\n        const input \u003d byId(\"modalInput\");\r\n        const okBtn \u003d byId(\"modalOkBtn\");\r\n\r\n        input.style.display \u003d type \u003d\u003d\u003d \"delete\" ? \"none\" : \"block\";\r\n        hint.style.display \u003d type \u003d\u003d\u003d \"delete\" ? \"none\" : \"block\";\r\n        okBtn.className \u003d \"btn \" + (type \u003d\u003d\u003d \"delete\" ? \"btn-danger\" : \"btn-primary\");\r\n        okBtn.innerText \u003d type \u003d\u003d\u003d \"delete\" ? t(\"Delete\") : t(\"OK\");\r\n\r\n        if (type \u003d\u003d\u003d \"rename\") {\r\n            title.innerText \u003d t(\"Rename\");\r\n            const base \u003d pathBaseName(selectedItem.fullPath);\r\n            const ext \u003d preservedExtension(base);\r\n            const baseOnly \u003d ext ? base.slice(0, base.length - ext.length) : base;\r\n            input.value \u003d baseOnly;\r\n            input.placeholder \u003d ext ? t(\"New name (without extension)\") : t(\"New name\");\r\n            hint.innerText \u003d ext\r\n                ? t(\"Full path stays in the current folder; extension {ext} is kept unless you type it.\", {ext})\r\n                : t(\"New name in the current folder (full path is built automatically).\");\r\n        }\r\n        if (type \u003d\u003d\u003d \"delete\") {\r\n            title.innerText \u003d t(\"Delete?\");\r\n            hint.innerText \u003d \"\";\r\n            input.value \u003d \"\";\r\n        }\r\n\r\n        setTimeout(() \u003d\u003e {\r\n            if (type !\u003d\u003d \"delete\") {\r\n                input.focus();\r\n            }\r\n        }, 50);\r\n    }\r\n\r\n    function closeModal() {\r\n        byId(\"modal\").classList.remove(\"is-open\");\r\n    }\r\n\r\n    async function confirmModal() {\r\n        const input \u003d byId(\"modalInput\");\r\n        try {\r\n            if (modalAction \u003d\u003d\u003d \"rename\") {\r\n                const oldFull \u003d selectedItem.fullPath;\r\n                const isDir \u003d !!selectedItem.isDirectory;\r\n                const oldBase \u003d pathBaseName(oldFull);\r\n                const newBase \u003d buildRenameNewBase(input.value, oldBase);\r\n                let newFull \u003d joinDirAndName(parentDirOf(oldFull), newBase);\r\n                if (isDir) {\r\n                    newFull \u003d newFull.replace(/\\/+$/, \"\") + \"/\";\r\n                }\r\n                const src \u003d pathTripleFromFs(oldFull, isDir);\r\n                const dst \u003d pathTripleFromFs(newFull, isDir);\r\n                const res \u003d await fetchChecked(API + \"?cmd\u003drename\u0026\" + queryFromSrcDst(src, dst));\r\n                if (!res.ok) {\r\n                    throw httpError(res.status);\r\n                }\r\n            }\r\n            if (modalAction \u003d\u003d\u003d \"delete\") {\r\n                const delT \u003d pathTripleFromFs(selectedItem.fullPath, !!selectedItem.isDirectory);\r\n                const res \u003d await fetchChecked(API + \"?cmd\u003ddelete\u0026\" + queryFromTriple(delT));\r\n                if (!res.ok) {\r\n                    throw httpError(res.status);\r\n                }\r\n            }\r\n            closeModal();\r\n            await render();\r\n        } catch (err) {\r\n            showToast(actionErrorText(err), \"error\");\r\n        }\r\n    }\r\n\r\n    byId(\"modal\").addEventListener(\"click\", (e) \u003d\u003e {\r\n        if (e.target.id \u003d\u003d\u003d \"modal\") {\r\n            closeModal();\r\n        }\r\n    });\r\n\r\n    byId(\"list-error-retry\").addEventListener(\"click\", () \u003d\u003e {\r\n        render();\r\n    });\r\n\r\n    byId(\"list-error\").setAttribute(\"hidden\", \"true\");\r\n\r\n    document.addEventListener(\"click\", (e) \u003d\u003e {\r\n        if (e.target.closest(\".row-menu-wrap\")) {\r\n            return;\r\n        }\r\n        closeAllRowMenus();\r\n    });\r\n    byId(\"table-scroll\").addEventListener(\"scroll\", closeAllRowMenus, {passive: true});\r\n    window.addEventListener(\"resize\", closeAllRowMenus);\r\n    document.addEventListener(\"keydown\", (e) \u003d\u003e {\r\n        if (e.key \u003d\u003d\u003d \"Escape\") {\r\n            closeAllRowMenus();\r\n        }\r\n    });\r\n\r\n    applyStaticI18n();\r\n    applyUploadHint();\r\n    applyUploadInputFilters();\r\n    updateClipboardUi();\r\n    const pathEl \u003d byId(\"path\");\r\n    pathEl.value \u003d currentPath;\r\n    updateNavUpButtonState();\r\n    pathEl.addEventListener(\"keydown\", (e) \u003d\u003e {\r\n        if (e.key \u003d\u003d\u003d \"Enter\") {\r\n            e.preventDefault();\r\n            applyPathNavigation();\r\n        }\r\n    });\r\n    byId(\"path-go-btn\").addEventListener(\"click\", (e) \u003d\u003e {\r\n        e.preventDefault();\r\n        applyPathNavigation();\r\n    });\r\n    byId(\"clip-paste-btn\").addEventListener(\"click\", (e) \u003d\u003e {\r\n        e.preventDefault();\r\n        pasteClipboardIntoCurrentFolder();\r\n    });\r\n    byId(\"clip-cancel-btn\").addEventListener(\"click\", (e) \u003d\u003e {\r\n        e.preventDefault();\r\n        cancelClipboard();\r\n    });\r\n    byId(\"upload-trigger\").addEventListener(\"click\", () \u003d\u003e {\r\n        byId(\"upload-input\").click();\r\n    });\r\n    byId(\"upload-input\").addEventListener(\"change\", (e) \u003d\u003e {\r\n        const inp \u003d e.target;\r\n        const fl \u003d inp.files;\r\n        inp.value \u003d \"\";\r\n        runUploads(fl);\r\n    });\r\n\r\n    render();\r\n\u003c/script\u003e\r\n\r\n\u003c/body\u003e\r\n\u003c/html\u003e","option":1,"responseCode":"OK","text":"","disableLogging":false,"m_SIGUID":-6444287452409996359,"m_classType":"HttpServerResponseAction","m_constraintList":[],"m_isDisabled":false,"m_isOrCondition":false},{"disableLogging":false,"m_SIGUID":-7618865855499052607,"m_classType":"EndIfAction","m_constraintList":[],"m_isDisabled":false,"m_isOrCondition":false},{"color":-1,"separatorLabel":"Finishing","disableLogging":false,"m_SIGUID":-9207060925101921877,"m_classType":"SeparatorAction","m_constraintList":[],"m_isDisabled":false,"m_isOrCondition":false},{"variableNames":["cmd","files","filesJson","type","request","responseDict","responseDict"],"disableLogging":false,"m_SIGUID":-4774586595915081277,"m_classType":"ClearVariablesAction","m_constraintList":[],"m_isDisabled":false,"m_isOrCondition":false}],"m_category":"Инструменты","m_constraintList":[],"m_description":"🤖 Web file manager for MacroDroid.\r\n\r\n⭐️ Key features:\r\n🌐 Access files via browser (MacroDroid HTTP server)\r\n📂 Navigate through folders starting from a specified path (/sdcard/ by default)\r\n📄 View directory contents in a user-friendly interface\r\n📥 Download files (in development)\r\n📤 Upload files (in development)\r\n🗑️ Delete files and folders\r\n📁 Create new directories\r\n📋 Copy files\r\n✂️ Move files between folders\r\n📊 Display file information (size, date)\r\n🌍 Multilingual interface\r\n🔐 Work on a local network (Wi-Fi / hotspot) without the cloud\r\n\r\n⚙️ Macro settings:\r\n🌐 Make sure the device and client are on the same network\r\n🔢 If necessary, change the port in the port variable (default 8080)\r\n📂 Set the starting directory in rootPath (e.g. /sdcard/)\r\n📎 Configure allowed extensions for downloading in allowedFileExt\r\n🌍 If necessary, select a language in currentLang\r\n🔗 Open in a browser: http://device_IP:port/rfm\r\n\r\n💡 Features:\r\n⚡ Works completely locally - no third-party servers\r\n🧠 Uses MacroDroid\u0027s built-in HTTP Server\r\n📱 Convenient for quickly accessing phone files from a PC\r\n🛠️ Easily extendable for your own scenarios.","m_descriptionOpen":false,"m_enabled":false,"m_excludeLog":false,"m_headingColor":-11382190,"m_isOrCondition":false,"m_name":"Remote Filemanager 📁","m_triggerList":[{"identifier":"rfm","ipAddressWhiteList":[],"queryParamsDictionaryKeys":{"keys":[]},"queryParamsDictionaryName":"request","responseCode":"OK","responseText":"{lv\u003dresponseDict}","saveBodyToFile":false,"saveBodyToFileDirectory":"","saveBodyToFileFilename":"","sendResponse":false,"variableWhiteList":[],"variableWhiteListEnabled":false,"disableLogging":false,"m_SIGUID":-7409972574789710784,"m_classType":"HttpServerTrigger","m_comment":"Main address","m_constraintList":[],"m_isDisabled":false,"m_isOrCondition":false},{"headerParams":[],"identifier":"rfm/upload","ipAddressWhiteList":[],"queryParamsDictionaryKeys":{"keys":[]},"queryParamsDictionaryName":"request","responseCode":"OK","responseText":"OK","saveBodyToFile":true,"saveBodyToFileDirectory":"/storage/emulated/0/Download/4pda","saveBodyToFileFilename":"test.txt","sendResponse":true,"variableWhiteList":[],"variableWhiteListEnabled":false,"disableLogging":false,"m_SIGUID":-5184600700772686607,"m_classType":"HttpServerTrigger","m_comment":"File upload address","m_constraintList":[],"m_isDisabled":false,"m_isOrCondition":false},{"color":-1,"label":"Automatic start/stop","disableLogging":false,"m_SIGUID":-5412161046910975700,"m_classType":"SeparatorTrigger","m_constraintList":[],"m_isDisabled":false,"m_isOrCondition":false},{"customAddedSSIDs":[],"m_SSIDList":["Любая сеть"],"m_wifiState":2,"disableLogging":false,"m_SIGUID":-8559277199786924438,"m_classType":"WifiConnectionTrigger","m_comment":"You can select secure wi-fi networks here, when connected to which this macro will work","m_constraintList":[],"m_isDisabled":false,"m_isOrCondition":false},{"customAddedSSIDs":[],"m_SSIDList":["Любая сеть"],"m_wifiState":3,"disableLogging":false,"m_SIGUID":-6060073764503945374,"m_classType":"WifiConnectionTrigger","m_constraintList":[],"m_isDisabled":false,"m_isOrCondition":false}]},"macroExportVersion":1}