mment":"","m_constraintList":[],"m_isDisabled":false,"m_isOrCondition":false},{"booleanDictionaryKeys":{"keys":[]},"dictionaryKeys":[],"dictionaryOrArrayType":-1,"existingManualKeyType":0,"m_booleanInvert":false,"m_darkMode":-1,"m_doubleRandomMax":0.0,"m_doubleRandomMin":0.0,"m_falseLabel":"Ложь","m_intExpression":false,"m_intRandom":false,"m_intRandomMax":0,"m_intRandomMin":0,"m_intValueDecrement":false,"m_intValueIncrement":false,"m_newBooleanValue":true,"m_newDoubleValue":0.0,"m_newIntValue":0,"m_trueLabel":"Истина","m_userPrompt":false,"m_userPromptEmptyAtStart":false,"m_userPromptPassword":false,"m_userPromptPasswordToggle":false,"m_userPromptShowCancel":true,"m_userPromptStopAfterCancel":true,"m_variable":{"description":"System: A violation was detected","dictionary":{"entries":[],"isArray":false,"variableType":4,"type":"Dictionary"},"isActionBlockWorkingVar":true,"isLocalVar":true,"isSecure":true,"m_booleanValue":false,"m_decimalValue":0.0,"m_intValue":0,"m_name":"violationDetect","m_stringValue":"","m_type":0,"supportsInput":false,"supportsOutput":true},"disableLogging":false,"m_SIGUID":-6548670922893918826,"m_classType":"SetVariableAction","m_comment":"Fitting a flag about a recorded violation","m_constraintList":[],"m_isDisabled":false,"m_isOrCondition":false},{"color":-1,"separatorLabel":"","disableLogging":false,"m_SIGUID":-6823538455417203368,"m_classType":"SeparatorAction","m_comment":"","m_constraintList":[],"m_isDisabled":false,"m_isOrCondition":false},{"allFilesPath":"{lv\u003dpathToFiles}","applyAutoFocus":false,"m_flashOption":0,"m_showIcon":false,"m_useFrontCamera":true,"pathName":"primary:MacroDroid/IntruderCam","pathUri":"content://com.android.externalstorage.documents/tree/primary%3AMacroDroid%2FIntruderCam","useAllFilesAccess":true,"disableLogging":false,"m_SIGUID":-8553264332285210223,"m_classType":"TakePictureAction","m_comment":"Set path to: /sdcard/MacroDroid/IntruderCam","m_constraintList":[],"m_isDisabled":false,"m_isOrCondition":false},{"m_delayInMilliSeconds":0,"m_delayInSeconds":5,"m_useAlarm":true,"unitForVariables":0,"disableLogging":false,"m_SIGUID":-4656335925063280147,"m_classType":"PauseAction","m_comment":"","m_constraintList":[],"m_isDisabled":false,"m_isOrCondition":false},{"allFilesPath":"{lv\u003dpathToFiles}","applyAutoFocus":false,"m_flashOption":0,"m_showIcon":false,"m_useFrontCamera":false,"pathName":"primary:MacroDroid/IntruderCam","pathUri":"content://com.android.externalstorage.documents/tree/primary%3AMacroDroid%2FIntruderCam","useAllFilesAccess":true,"disableLogging":false,"m_SIGUID":-7675585541145217538,"m_classType":"TakePictureAction","m_comment":"Set path to: /sdcard/MacroDroid/IntruderCam","m_constraintList":[],"m_isDisabled":false,"m_isOrCondition":false},{"color":-1,"separatorLabel":"","disableLogging":false,"m_SIGUID":-8147673304279716734,"m_classType":"SeparatorAction","m_comment":"","m_constraintList":[],"m_isDisabled":false,"m_isOrCondition":false},{"booleanDictionaryKeys":{"keys":[]},"dictionaryKeys":[],"dictionaryOrArrayType":-1,"existingManualKeyType":0,"m_booleanInvert":false,"m_darkMode":-1,"m_doubleRandomMax":0.0,"m_doubleRandomMin":0.0,"m_falseLabel":"Ложь","m_intExpression":false,"m_intRandom":false,"m_intRandomMax":0,"m_intRandomMin":0,"m_intValueDecrement":false,"m_intValueIncrement":false,"m_newBooleanValue":false,"m_newDoubleValue":0.0,"m_newIntValue":0,"m_newStringValue":"\u003c!DOCTYPE html\u003e\n\u003chtml lang\u003d\"{lv\u003dcurrentLang}\"\u003e\n\u003chead\u003e\n  \u003cmeta charset\u003d\"UTF-8\"\u003e\n  \u003cmeta name\u003d\"viewport\" content\u003d\"width\u003ddevice-width, initial-scale\u003d1.0\"\u003e\n  \u003ctitle\u003eIntruderCam📍{lv\u003dlangs[{lv\u003dcurrentLang}][Coordinates of violation]}\u003c/title\u003e\n  \u003clink rel\u003d\"stylesheet\" href\u003d\"https://cdn.jsdelivr.net/npm/ol@9.1.0/ol.css\"\u003e\n  \u003cstyle\u003e\n    html, body {\n      margin: 0;\n      padding: 0;\n      height: 100%;\n      background: #f0f0f0;\n      font-family: sans-serif;\n      display: flex;\n      flex-direction: column;\n      align-items: center;\n      justify-content: center;\n    }\n    body {\n        padding: 10px;\n    }\n    #map {\n      width: 100%;\n      height: 80%;\n      border-radius: 10px;\n      box-shadow: 0 2px 6px rgba(0,0,0,0.2);\n    }\n    #info {\n      margin-bottom: 10px;\n      font-size: 14px;\n      color: #333;\n    }\n  \u003c/style\u003e\n\u003c/head\u003e\n\u003cbody\u003e\n\n\u003ch3\u003e🗺️ IntruderCam - {lv\u003dlangs[{lv\u003dcurrentLang}][Location of the violation]}\u003c/h3\u003e\n\u003cdiv id\u003d\"info\"\u003e\u003c/div\u003e\n\u003cdiv id\u003d\"map\"\u003e\u003c/div\u003e\n\u003cdiv id\u003d\"photos\"\u003e\u003c/div\u003e\n\n\u003cscript src\u003d\"https://cdn.jsdelivr.net/npm/ol@9.1.0/dist/ol.js\"\u003e\u003c/script\u003e\n\u003cscript\u003e\n(function() {\n  try {\n    const gpsData \u003d {\n      lat: {last_loc_lat},\n      lon: {last_loc_long},\n      time: \u0027{year}-{month_digit}-{dayofmonth} {hour_0}:{minute}:{second}\u0027\n    };\n\n    if (!gpsData || isNaN(gpsData.lat) || isNaN(gpsData.lon)) {\n      document.getElementById(\u0027map\u0027).innerHTML \u003d\n        \u0027\u003cdiv style\u003d\"text-align:center;color:#666;margin-top:40%\"\u003eThere is no coordinate data\u003c/div\u003e\u0027;\n      return;\n    }\n\n    const info \u003d document.getElementById(\u0027info\u0027);\n    info.textContent \u003d `⏱ ${gpsData.time} | 📍 ${gpsData.lat.toFixed(5)}, ${gpsData.lon.toFixed(5)}`;\n\n    const map \u003d new ol.Map({\n      target: \u0027map\u0027,\n      layers: [\n        new ol.layer.Tile({\n          source: new ol.source.XYZ({\n            url: \u0027https://tile.openstreetmap.org/{z}/{x}/{y}.png\u0027,\n            attributions: \u0027© OpenStreetMap contributors\u0027\n          })\n        })\n      ],\n      view: new ol.View({\n        center: ol.proj.fromLonLat([gpsData.lon, gpsData.lat]),\n        zoom: 15\n      })\n    });\n\n    const vectorSource \u003d new ol.source.Vector({\n      features: [\n        new ol.Feature({\n          geometry: new ol.geom.Point(ol.proj.fromLonLat([gpsData.lon, gpsData.lat]))\n        })\n      ]\n    });\n\n    const vectorLayer \u003d new ol.layer.Vector({\n      source: vectorSource,\n      style: new ol.style.Style({\n        image: new ol.style.Circle({\n          radius: 6,\n          fill: new ol.style.Fill({ color: \u0027#007bff\u0027 }),\n          stroke: new ol.style.Stroke({ color: \u0027#fff\u0027, width: 2 })\n        })\n      })\n    });\n\n    map.addLayer(vectorLayer);\n\n  } catch (e) {\n    console.error(\u0027Error\u0027, e);\n  }\n})();\n\u003c/script\u003e\n\n\u003c/body\u003e\n\u003c/html\u003e","m_trueLabel":"Истина","m_userPrompt":false,"m_userPromptEmptyAtStart":false,"m_userPromptPassword":false,"m_userPromptPasswordToggle":false,"m_userPromptShowCancel":true,"m_userPromptStopAfterCancel":true,"m_variable":{"description":"System: Generated HTML coordinate viewing template","dictionary":{"entries":[],"isArray":false,"variableType":4,"type":"Dictionary"},"isActionBlockWorkingVar":true,"isLocalVar":true,"isSecure":true,"m_booleanValue":false,"m_decimalValue":0.0,"m_intValue":0,"m_name":"gpsCoordinatesViewer","m_stringValue":"","m_type":2,"supportsInput":false,"supportsOutput":true},"disableLogging":false,"m_SIGUID":-7565033085945892017,"m_classType":"SetVariableAction","m_comment":"Forming an HTML GPS viewing template","m_constraintList":[],"m_isDisabled":false,"m_isOrCondition":false},{"allFilesPath":"{lv\u003dpathToFiles}","m_append":false,"m_filename":"{lv\u003dlastDateTime}.html","m_logText":"{lv\u003dgpsCoordinatesViewer}","m_pathName":"/IntruderCam","m_pathUri":"content://com.android.externalstorage.documents/tree/primary%3AMacroDroid%2FIntruderCam","m_prepend":false,"overwrite":true,"useAllFilesAccess":true,"disableLogging":false,"m_SIGUID":-6220506375565860552,"m_classType":"WriteToFileAction","m_comment":"Set pat