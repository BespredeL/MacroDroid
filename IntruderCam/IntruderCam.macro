31231789,"m_imageResourceName":"ic_do_not_touch","m_macroGUIDToRun":-4734495940035911251,"m_notificationChannelType":1,"m_notificationSubject":"IntruderCam","m_notificationText":"{lv\u003dlangs[{lv\u003dcurrentLang}][A violation was recorded]}","m_overwriteExisting":false,"m_priority":0,"m_ringtoneIndex":0,"m_ringtoneName":"По умолчанию","m_runMacroWhenPressed":true,"m_textColor":-1,"macroNameToRun":"[Этот макрос]","maintainSpaces":false,"notificationActionButtons":[{"clearOnPress":false,"label":"{lv\u003dlangs[{lv\u003dcurrentLang}][Open the latest records]}","macroGuid":-4734495940035911251,"macroName":"[Этот макрос]"}],"notificationChannelName":"Уведомление (высокий приоритет)","notificationIdString":"0","notificatonId":0,"preventAndroid16Grouping":false,"preventBackButtonClosing":false,"preventRemovalByBin":false,"showAsOverlayOption":1,"yPosition":0.5,"disableLogging":false,"m_SIGUID":-7492111519826367626,"m_classType":"NotificationAction","m_comment":"Violation notification if unlocked successfully","m_constraintList":[],"m_isDisabled":false,"m_isOrCondition":false},{"disableLogging":false,"m_SIGUID":-7641386316004477633,"m_classType":"EndIfAction","m_comment":"","m_constraintList":[],"m_isDisabled":false,"m_isOrCondition":false},{"color":-1,"separatorLabel":"","disableLogging":false,"m_SIGUID":-6336937059531868963,"m_classType":"SeparatorAction","m_comment":"","m_constraintList":[],"m_isDisabled":false,"m_isOrCondition":false},{"variableNames":["gpsCoordinatesViewer"],"disableLogging":false,"m_SIGUID":-5361867065983669124,"m_classType":"ClearVariablesAction","m_comment":"","m_constraintList":[],"m_isDisabled":false,"m_isOrCondition":false}],"m_category":"Безопасность","m_constraintList":[],"m_description":"📸 IntruderCam – защита от посторонних.\nНадёжный способ узнать, кто трогал ваш телефон без разрешения!\n----------\n⚙️ Перед первым использованием: \nВ действиях создания фото, видео и записи в файл, укажите путь к папке \"/sdcard/MacroDroid/IntruderCam\" для сохранения фото, видео и карты.\n----------\n🕵️ Что делает макрос:\n\n🤳 Делает фото с фронтальной и основной камеры при неудачных попытках входа (по умолчанию 2 попытки в течении 10 минут).\n\n🗺️ Сохраняет GPS-координаты в виде HTML-страницы с интерактивной картой.\n\n🎥 Записывает 30 секунд видео с фронтальной камеры.\n\n🔔 После успешной разблокировки показывает уведомление о нарушении, при нажатии на которое открывается папка с файлами\n----------\n🌐 Легко переводите макрос на свой язык в переменной \"langs\".\n----------\n👍 Credits to Stevieb for the Intruder photo:\nhttps://www.macrodroidlink.com/macrostore?id\u003d103","m_descriptionOpen":false,"m_enabled":false,"m_excludeLog":false,"m_headingColor":-11382190,"m_isOrCondition":false,"m_name":"IntruderCam 📸","m_triggerList":[{"m_numFailures":2,"m_timeIndex":3,"disableLogging":false,"m_SIGUID":-6703125094544590651,"m_classType":"FailedLoginTrigger","m_comment":"","m_constraintList":[],"m_isDisabled":false,"m_isOrCondition":false},{"disableLogging":false,"m_SIGUID":-5451991500036964032,"m_classType":"DeviceUnlockedTrigger","m_comment":"","m_constraintList":[],"m_isDisabled":false,"m_isOrCondition":false},{"disableLogging":false,"m_SIGUID":-6528121372927282506,"m_classType":"EmptyTrigger","m_comment":"","m_constraintList":[],"m_isDisabled":false,"m_isOrCondition":false}]},"macroExportVersion":1}